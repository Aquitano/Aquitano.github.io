---
interface Props {
    index: string;
    title: string;
}

const { index, title } = Astro.props;
---

<div class="border-line mb-10 flex items-baseline justify-between gap-6 border-t pt-5 md:mb-16">
    <h2 class="display text-[clamp(1.75rem,4.2vw,3rem)] leading-[1.05]">{title}</h2>
    <span class="meta shrink-0 tabular-nums"><span class="text-accent">/{index}</span></span>
</div>
