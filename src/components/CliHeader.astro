---
export interface Props {
    command: string;
    class?: string;
}

const { command, class: className } = Astro.props;
---

<div class:list={['cli-header', className]}>
    <span class="cli-prompt">$</span>
    <span class="text-text-secondary">{command}</span>
</div>

<style>
    @reference "../styles/global.css";

    .cli-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        @apply text-text-secondary font-mono text-sm;
    }

    .cli-prompt {
        color: var(--color-accent);
        font-weight: 700;
    }
</style>
