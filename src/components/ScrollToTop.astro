---
import { defaultLang, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

export interface Props {
    lang?: Lang;
}

const lang: Lang = Astro.props.lang ?? (Astro.currentLocale as Lang) ?? defaultLang;
const t = useTranslations(lang);
---

<button
    id="scroll-to-top"
    title={t('general.scrollToTop')}
    aria-label={t('general.scrollToTop')}
    class="scroll-top fixed right-8 bottom-8 z-50 h-11 w-11 rounded-full border-0 text-3xl font-bold text-white focus-visible:ring-4 focus-visible:ring-white/40 focus-visible:outline-none"
    >&uarr;</button
>

<style lang="scss">
    .scroll-top {
        background: var(--neutral-900);
        color: var(--neutral-100);
        opacity: 0;
        bottom: 14px;
        border: 0 none;
        border-radius: 23px;
        transition: background 0.2s ease-in-out;

        &:hover {
            background: var(--neutral-800);
        }
    }

    :global([data-theme='dark']) .scroll-top {
        background: rgba(255, 255, 255, 0.12);
        color: var(--neutral-100);

        &:hover {
            background: rgba(255, 255, 255, 0.2);
        }
    }

    @media (prefers-reduced-motion: no-preference) {
        .Fly-in-up {
            animation-name: Fly-in-up;
            animation-duration: 0.6s;
            animation-fill-mode: forwards;
        }

        .Fly-out-down {
            animation-name: Fly-out-down;
            animation-duration: 0.6s;
            animation-fill-mode: forwards;
        }

        @keyframes Fly-in-up {
            0% {
                opacity: 0;
                transform: translate3d(0, 25px, 0);
            }
            100% {
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
        }

        @keyframes Fly-out-down {
            0% {
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
            100% {
                opacity: 0;
                visibility: hidden;
                transform: translate3d(0, 25px, 0);
            }
        }
    }

    // Reduced-motion: toggle visibility instantly
    @media (prefers-reduced-motion: reduce) {
        .Fly-in-up {
            opacity: 1;
        }

        .Fly-out-down {
            opacity: 0;
            visibility: hidden;
        }
    }
</style>

<script>
    function handleScroll() {
        const scrollButton = document.querySelector('#scroll-to-top');
        if (!scrollButton) return;

        // Distance from top of page
        const scroll = document.documentElement.scrollTop || document.body.scrollTop;

        if (scroll > 1000) {
            scrollButton.classList.add('Fly-in-up');
            scrollButton.classList.remove('Fly-out-down');
        } else {
            if (scrollButton.classList.contains('Fly-in-up')) {
                scrollButton.classList.add('Fly-out-down');
                scrollButton.classList.remove('Fly-in-up');
            }
        }
    }

    function goToTop() {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.scrollTo({
            top: 0,
            behavior: prefersReducedMotion ? 'auto' : 'smooth',
        });
    }

    window.addEventListener('scroll', handleScroll, { passive: true });

    document.addEventListener('astro:page-load', () => {
        const scrollButton = document.querySelector('#scroll-to-top');
        scrollButton?.addEventListener('click', goToTop);

        handleScroll();
    });
</script>
