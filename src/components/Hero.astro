---
import { site } from '../lib/data';
import Magnetic from './Magnetic.astro';
---

<section id="top" data-hero data-minimap="Intro" class="relative flex min-h-svh flex-col justify-end overflow-hidden">
    {/* fade shader into page background at the bottom edge */}
    <div class="to-bg pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent"></div>

    <div class="relative z-10 px-5 pb-10 md:px-10 md:pb-14">
        <div data-hero-parallax>
            <p data-hero-fade class="meta text-fg/70 mb-5 flex flex-wrap items-center gap-x-3 gap-y-1">
                <span>{site.role} · {site.status}</span>
                <span aria-hidden="true" class="text-line">/</span>
                <span class="text-acid">{site.availability}</span>
            </p>
            <h1 class="display text-[clamp(3.6rem,15.5vw,15rem)]">
                <span class="block overflow-hidden pb-[0.06em]">
                    <span data-hero-line class="split-line block">Thomas</span>
                </span>
                <span class="block overflow-hidden pb-[0.06em]">
                    <span data-hero-line class="split-line display-outline block">Breindl</span>
                </span>
            </h1>
        </div>

        <div
            class="border-line mt-8 flex flex-col gap-8 border-t pt-6 md:mt-12 md:flex-row md:items-end md:justify-between"
        >
            <p data-hero-fade class="text-muted max-w-md text-base leading-relaxed md:text-lg">
                Building robust backend systems, event pipelines, and interfaces people enjoy using. Currently studying
                CS in <span class="text-fg">Passau, Germany</span>.
            </p>
            <div data-hero-fade class="flex flex-wrap items-center gap-3">
                <Magnetic class="inline-flex">
                    <a
                        href="#work"
                        class="cta-glide pressable bg-acid flex items-center gap-2 rounded-full px-6 py-3 font-mono text-xs font-medium tracking-[0.14em] text-black uppercase"
                    >
                        <span class="cta-glide-label">
                            <span class="cta-glide-label-in">View Work</span>
                            <span class="cta-glide-label-out" aria-hidden="true">View Work</span>
                        </span>
                        <span class="cta-glide-arrow" aria-hidden="true">→</span>
                    </a>
                </Magnetic>
                <a href="#about" aria-label="Scroll to about section" class="group ml-1 flex items-center gap-2.5">
                    <span class="meta group-hover:text-acid transition-colors duration-300">Scroll</span>
                    <span
                        class="border-fg/20 text-acid group-hover:border-acid grid size-11 place-items-center overflow-hidden rounded-full border transition-colors duration-300"
                    >
                        <svg
                            class="scroll-cue-arrow"
                            width="11"
                            height="13"
                            viewBox="0 0 10 12"
                            fill="none"
                            aria-hidden="true"
                        >
                            <path d="M5 1v10m0 0L1 7m4 4 4-4" stroke="currentColor" stroke-width="1.2"></path>
                        </svg>
                    </span>
                </a>
            </div>
        </div>
    </div>
</section>

{/* Pre-hide animated elements so they don't flash before the intro runs (motion users only) */}
<style>
    @media (prefers-reduced-motion: no-preference) {
        [data-hero-line] {
            transform: translateY(110%);
        }
        [data-hero-fade] {
            opacity: 0;
        }
    }
</style>

<script>
    import { gsap, prefersReducedMotion } from '../lib/gsap';

    const root = document.querySelector<HTMLElement>('[data-hero]');
    if (root && !prefersReducedMotion()) {
        // y: 0 clears the px baseline GSAP would otherwise inherit from the
        // pre-hide CSS matrix (translateY(110%)), which would survive the yPercent tween.
        gsap.set('[data-hero-line]', { y: 0, yPercent: 110 });
        gsap.set('[data-hero-fade]', { autoAlpha: 0, y: 24 });

        const tl = gsap.timeline({
            delay: 0.15,
            onComplete: () => gsap.set('[data-hero-line]', { willChange: 'auto' }),
        });
        tl.to('[data-hero-line]', {
            yPercent: 0,
            duration: 1.2,
            ease: 'power4.out',
            stagger: 0.09,
        }).to('[data-hero-fade]', { autoAlpha: 1, y: 0, duration: 0.9, stagger: 0.07 }, '-=0.7');

        // Parallax the headline as the hero scrolls away
        gsap.to('[data-hero-parallax]', {
            yPercent: 14,
            autoAlpha: 0.4,
            ease: 'none',
            scrollTrigger: { trigger: root, start: 'top top', end: 'bottom top', scrub: true },
        });
    }
</script>
