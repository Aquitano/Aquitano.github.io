---
import { Icon } from 'astro-icon/components';

export interface Props {
    text: string;
    icon: string;
    href: string;
    style?: string;
    target?: string;
    rel?: 'noopener noreferrer' | 'noopener' | 'noreferrer' | 'prefetch' | 'none';
    variant?: 'icon' | 'pill';
}

const { text, icon, href, style, target, rel, variant = 'pill' } = Astro.props;
---

<a
    href={href}
    class:list={[
        'special',
        variant === 'icon'
            ? 'link-btn-icon flex h-10 w-10 items-center justify-center rounded-full transition-transform duration-200 hover:-translate-y-0.5'
            : 'link-btn-pill flex items-center justify-center rounded-xl px-4 py-2 transition-all duration-300',
    ]}
    target={target}
    rel={rel}
    aria-label={text}
>
    {
        variant === 'icon' ? (
            <Icon name={icon} style={style} />
        ) : (
            <>
                <div>
                    <Icon name={icon} style={style} />
                </div>
                <div class="link-btn-divider mx-3 h-4 border-l" />
                <div class="link-btn-text">{text}</div>
            </>
        )
    }
</a>

<style lang="scss">
    [data-icon] {
        color: currentColor;
        @apply text-base;
    }

    .link-btn-icon {
        background: var(--neutral-900);
        color: var(--neutral-100);
        box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.1);
    }

    .link-btn-icon:hover {
        background: var(--neutral-800);
    }

    :global([data-theme='dark']) .link-btn-icon {
        background: var(--neutral-200);
        color: var(--neutral-900);
    }

    :global([data-theme='dark']) .link-btn-icon:hover {
        background: var(--neutral-300);
    }

    .link-btn-pill {
        background: var(--neutral-900);
        color: var(--neutral-100);
    }

    .link-btn-pill:hover {
        background: var(--neutral-800);
    }

    :global([data-theme='dark']) .link-btn-pill {
        background: var(--neutral-200);
        color: var(--neutral-900);
    }

    :global([data-theme='dark']) .link-btn-pill:hover {
        background: var(--neutral-300);
    }

    .link-btn-divider {
        border-color: var(--neutral-600);
    }

    :global([data-theme='dark']) .link-btn-divider {
        border-color: var(--neutral-400);
    }

    .link-btn-text {
        color: inherit;
    }
</style>
