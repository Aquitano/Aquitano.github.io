<section class="home-top landingpage" aria-labelledby="hero-title">
    <div class="flex flex-col items-center">
        <div class="text-center">
            <h1 id="hero-title" class="title font-extrabold text-[var(--color-text-primary)]">
                <span class="word">Thomas</span>
                <span class="word">Breindl</span>
            </h1>
            <p class="hero-subtitle text-[var(--color-text-secondary)]">
                Hallo, ich bin Programmierer, Designer und Student.
            </p>
            <nav class="links" aria-label="Hauptlinks im Hero">
                <a
                    href="#portfolio"
                    class="link link-underline scroll-to projects cursor-pointer"
                >
                    Projekte
                </a>
                <span class="links-sep" aria-hidden="true">oder</span>
                <a href="/timeline" class="link link-underline" data-astro-prefetch>Über Mich</a>
            </nav>
        </div>
        <button
            type="button"
            class="scroll-trigger animate"
            aria-label="Zum Portfolio scrollen"
        >
            <span class="scroll-to-icon" aria-hidden="true"></span>
        </button>
    </div>
</section>

<style>
    .home-top {
        font-family: var(--font-body);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        min-height: 100dvh;
        /* Account for sticky header height to center content in remaining space */
        padding-top: clamp(60px, 8vh, 100px);
        z-index: 2;
    }

    .home-top::before {
        content: '';
        position: absolute;
        inset: -60px 0 0;
        pointer-events: none;
        background: radial-gradient(900px 200px at 50% 0, var(--color-border-subtle), transparent 65%);
    }

    .title {
        font-family: var(--font-display);
        line-height: var(--leading-none);
        letter-spacing: var(--tracking-tight);
        font-size: clamp(2.75rem, 7vw + 1rem, 7.5rem);
        margin-bottom: clamp(0.5rem, 1vw, 1rem);
        text-wrap: balance;
    }

    .title .word {
        display: block;
    }

    .hero-subtitle {
        font-size: var(--text-2xl);
        font-family: var(--font-body);
        margin-bottom: var(--space-4);
        max-width: 34ch;
        margin-left: auto;
        margin-right: auto;
        line-height: var(--leading-snug);
        text-wrap: balance;
    }

    .link {
        font-weight: var(--font-extrabold);
        letter-spacing: normal;
        text-transform: uppercase;
        font-size: var(--text-lg);
        color: var(--color-text-primary);
        transition: color var(--duration-fast) var(--ease-out);
    }

    .link:hover {
        color: var(--color-accent);
    }

    .link-underline {
        border-bottom-width: 0;
        background-image: linear-gradient(transparent, transparent), linear-gradient(var(--color-accent), var(--color-accent));
        background-size: 0 3px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        transition: 
            background-size var(--duration-normal) var(--ease-out),
            color var(--duration-fast) var(--ease-out);
    }

    .link-underline:hover {
        background-size: 100% 3px;
        background-position: 0 100%;
    }

    .links {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-5);
        margin-top: var(--space-2);
        flex-direction: column;
    }

    .links-sep {
        font-weight: var(--font-bold);
        letter-spacing: var(--tracking-wide);
        color: var(--color-text-tertiary);
        text-transform: uppercase;
        font-size: var(--text-sm);
    }

    @media (min-width: 640px) {
        .links {
            flex-direction: row;
        }
    }

    /* Scroll trigger button */
    .scroll-trigger {
        background: transparent;
        border: 0;
        padding: 0;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        outline: none;
        margin-top: var(--space-8);
    }

    .scroll-trigger:focus-visible .scroll-to-icon {
        box-shadow:
            inset 0 0 0 2px var(--color-text-primary),
            0 0 0 var(--focus-ring-width) var(--focus-ring-color);
    }

    .scroll-to-icon {
        width: 20px;
        height: 30px;
        box-shadow: inset 0 0 0 2px var(--color-text-primary);
        border-radius: var(--radius-full);
        cursor: pointer;
        transition: box-shadow var(--duration-fast) var(--ease-out);
        position: relative;
    }

    .scroll-to-icon::after {
        content: '';
        width: 4px;
        height: 6px;
        background: var(--color-text-primary);
        top: 8px;
        right: 8px;
        border-radius: 2px;
        position: absolute;
        animation-duration: 1.5s;
        animation-iteration-count: infinite;
        animation-name: scroll;
    }

    .scroll-trigger:hover .scroll-to-icon {
        box-shadow: inset 0 0 0 2px var(--color-accent);
    }

    .scroll-trigger:hover .scroll-to-icon::after {
        background: var(--color-accent);
    }

    @media (min-width: 768px) and (min-height: 620px), (min-width: 1280px) {
        .scroll-trigger {
            display: inline-flex;
        }
    }

    /* Scroll animation - respect reduced motion */
    @media (prefers-reduced-motion: no-preference) {
        @keyframes scroll {
            0% {
                opacity: 1;
                transform: translateY(0);
            }
            50% {
                opacity: 1;
                transform: translateY(7px);
            }
            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .scroll-to-icon::after {
            animation: none;
        }
    }
</style>

<script>
    import { animate, stagger } from 'motion';

    function initHeroSection() {
        const scrollTriggers = document.querySelectorAll<HTMLElement>('.scroll-trigger, button.scroll-to, a.projects');
        scrollTriggers.forEach((el) =>
            el.addEventListener('click', (event) => {
                event.preventDefault();
                scrollToPortfolio();
            }),
        );
    }

    function scrollToPortfolio() {
        const portfolio = document.querySelector<HTMLElement>('#portfolio');
        if (!portfolio) return;
        const stickyHeader = document.querySelector('header');
        const headerOffset = stickyHeader instanceof HTMLElement ? stickyHeader.offsetHeight : 150;
        const rect = portfolio.getBoundingClientRect();
        const targetTop = rect.top + window.scrollY - headerOffset;
        window.scrollTo({ top: targetTop, behavior: 'smooth' });
    }

    const createSpan = (text: string | null) => {
        const node = document.createElement('span');
        node.textContent = text;
        return node;
    };

    const splitByLetter = (text: string | null | undefined) => (text ? [...text].map(createSpan) : []);

    const motionOK = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
    let heroAnim: ReturnType<typeof animate> | null = null;

    function runHeroLetters() {
        if (!motionOK) {
            // Show elements immediately without animation
            const elements = document.querySelectorAll<HTMLElement>('.header-light, .hero-subtitle, .links, .animate');
            elements.forEach((el) => {
                el.style.opacity = '1';
            });
            return;
        }

        if (!document.querySelector('.title .letter')) {
            const words = document.querySelectorAll<HTMLElement>('.title .word');
            words.forEach((wordEl) => {
                const nodes = splitByLetter(wordEl.textContent);
                wordEl.textContent = '';
                nodes.forEach((node) => {
                    if (node.textContent === ' ') {
                        wordEl.append(' ');
                        return;
                    }
                    node.classList.add('letter');
                    node.style.display = 'inline-block';
                    wordEl.appendChild(node);
                });
            });
        }

        const letters = document.querySelectorAll<HTMLElement>('.title .letter');
        letters.forEach((el) => {
            el.style.opacity = '0';
            el.style.transform = 'translate3d(0, 25px, 0)';
            el.style.filter = 'blur(5px)';
            el.style.willChange = 'opacity, transform, filter';
        });

        const step = 0.075;
        const letterDuration = 0.8;
        const lastLetterEndAt = letters.length ? (letters.length - 1) * step + letterDuration : 0;

        const sequence = [
            [
                Array.from(letters),
                {
                    y: [50, 0],
                    opacity: [0, 1],
                    filter: ['blur(5px)', 'blur(0)'],
                },
                { duration: letterDuration, delay: stagger(step, { startDelay: 0.3 }), ease: 'easeOut' },
            ],
            [
                '.hero-subtitle',
                {
                    opacity: [0, 1],
                    y: [50, 0],
                    filter: ['blur(5px)', 'blur(0)'],
                },
                { at: Math.max(0, lastLetterEndAt - 0.3), duration: 0.75, ease: 'easeOut' },
            ],
            [
                '.links',
                {
                    opacity: [0, 1],
                    y: [25, 0],
                    filter: ['blur(5px)', 'blur(0)'],
                },
                { at: Math.max(0, lastLetterEndAt - 0.05), duration: 0.7, ease: 'easeOut' },
            ],
            [
                '.animate',
                {
                    opacity: [0, 1],
                    y: [25, 0],
                },
                { at: lastLetterEndAt + 0.1, duration: 0.7, ease: 'easeOut' },
            ],
        ];

        heroAnim?.stop();
        heroAnim = animate(sequence as any);
        heroAnim.finished.then(() => {
            const all = document.querySelectorAll<HTMLElement>('.title .letter, .hero-subtitle, .links, .animate');
            all.forEach((el) => {
                el.style.willChange = 'auto';
            });
            document.dispatchEvent(new CustomEvent('hero:sequence-done'));
        });
    }

    // Initialize
    initHeroSection();
    window.addEventListener('load', runHeroLetters);
    document.addEventListener('astro:page-load', runHeroLetters);
    document.addEventListener('astro:after-swap', () => {
        initHeroSection();
        runHeroLetters();
    });
    document.addEventListener('astro:before-swap', () => {
        heroAnim?.stop();
        heroAnim = null;
    });
</script>
