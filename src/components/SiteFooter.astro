---
import { site, socials } from '../lib/data';
---

<footer
    id="contact"
    data-footer
    data-minimap="Contact"
    class="section-x section-y--major relative overflow-hidden pb-8"
>
    <div class="mb-16 md:mb-24">
        <p data-footer-reveal class="meta mb-6"><span class="text-accent">/05</span> Got an interesting problem?</p>
        <a href={`mailto:${site.email}`} class="group block">
            <span class="block overflow-hidden pb-[0.06em]">
                <span
                    data-footer-headline
                    class="display group-hover:text-accent block text-[clamp(2.8rem,11.5vw,11rem)] transition-colors duration-300"
                >
                    Let’s <span class="whitespace-nowrap"
                        >Talk<span
                            class="ease-out-strong ml-[0.1em] inline-block align-baseline text-[0.55em] transition-transform duration-300 group-hover:translate-x-[0.1em] group-hover:-translate-y-[0.1em]"
                            >↗</span
                        ></span
                    >
                </span>
            </span>
        </a>
        <div data-footer-reveal>
            <button
                data-copy-email
                data-email={site.email}
                type="button"
                aria-live="polite"
                class="pressable group/copy text-muted hover:text-fg mt-6 flex cursor-pointer items-center gap-3 font-mono text-xs transition-colors duration-200"
            >
                {site.email}
                <span
                    data-copy-default
                    class="border-line group-hover/copy:border-accent/60 group-hover/copy:text-accent rounded-full border px-2.5 py-0.5 text-[0.625rem] tracking-[0.12em] uppercase transition-colors duration-200"
                >
                    Copy
                </span>
                <span
                    data-copy-done
                    class="pop-in bg-accent hidden rounded-full border border-transparent px-2.5 py-0.5 text-[0.625rem] font-medium tracking-[0.12em] text-black uppercase"
                >
                    Copied <span aria-hidden="true">✓</span>
                </span>
            </button>
        </div>
    </div>

    <div data-footer-reveal class="border-line grid gap-px border-y sm:grid-cols-3">
        {
            socials.map((social) => (
                <a
                    href={social.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group border-line hover:bg-bg-raise flex items-center justify-between px-1 py-5 transition-colors duration-300 sm:border-r sm:px-5 sm:last:border-r-0"
                >
                    <div>
                        <p class="text-sm font-medium">{social.label}</p>
                        <p class="text-muted font-mono text-[0.6875rem]">{social.handle}</p>
                    </div>
                    <span class="text-muted group-hover:text-accent group-focus-visible:text-accent ease-out-strong transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-focus-visible:translate-x-0.5 group-focus-visible:-translate-y-0.5">
                        ↗
                    </span>
                </a>
            ))
        }
    </div>

    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="meta">©2026 {site.name} · {site.location}</p>
        <div class="flex items-center gap-8">
            <a href="#top" class="link-line touch-target meta text-fg inline-block">Back to top ↑</a>
        </div>
    </div>
</footer>

<style>
    @media (prefers-reduced-motion: no-preference) {
        :global(html.js) [data-footer-headline] {
            transform: translateY(110%);
        }
    }

    /* Pop for state-change feedback (the "Copied" pill) */
    .pop-in {
        animation: pop-in 320ms var(--ease-out-strong) both;
    }

    @keyframes pop-in {
        0% {
            transform: scale(0.5);
            opacity: 0;
        }
        70% {
            transform: scale(1.12);
        }
        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .pop-in {
            animation: none;
        }
    }
</style>

<script>
    import { gsap, prefersReducedMotion } from '../lib/gsap';

    const root = document.querySelector<HTMLElement>('[data-footer]');
    if (root && !prefersReducedMotion()) {
        gsap.set('[data-footer-headline]', { y: 0, yPercent: 110 });
        gsap.to('[data-footer-headline]', {
            yPercent: 0,
            duration: 1.1,
            ease: 'power4.out',
            scrollTrigger: { trigger: root, start: 'top 75%', once: true },
        });

        gsap.from('[data-footer-reveal]', {
            autoAlpha: 0,
            y: 48,
            duration: 1,
            stagger: 0.08,
            scrollTrigger: { trigger: root, start: 'top 75%', once: true },
        });
    }

    const btn = document.querySelector<HTMLButtonElement>('[data-copy-email]');
    const def = btn?.querySelector<HTMLElement>('[data-copy-default]');
    const done = btn?.querySelector<HTMLElement>('[data-copy-done]');
    if (btn && def && done) {
        let timer: ReturnType<typeof setTimeout>;

        const copy = async (text: string) => {
            if (!navigator.clipboard?.writeText) return false;
            await navigator.clipboard.writeText(text);
            return true;
        };

        const flash = () => {
            def.classList.add('hidden');
            done.classList.remove('hidden');
            clearTimeout(timer);
            timer = setTimeout(() => {
                done.classList.add('hidden');
                def.classList.remove('hidden');
            }, 2000);
        };

        btn.addEventListener('click', async () => {
            try {
                if (await copy(btn.dataset.email ?? '')) flash();
            } catch {
                // copy unavailable
            }
        });
    }
</script>
