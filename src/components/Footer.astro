---
const year = new Date().getFullYear();

interface FooterItem {
    label: string;
    href: string;
    external?: boolean;
}

interface FooterSection {
    title: string;
    items: FooterItem[];
}

const sections: FooterSection[] = [
    {
        title: 'Menu',
        items: [
            { label: 'Über mich', href: '/timeline' },
            { label: 'Projekte', href: '/#portfolio' },
            { label: 'Kontakt', href: '/contact' },
        ],
    },
    {
        title: 'Socials',
        items: [
            { label: 'LinkedIn', href: 'https://www.linkedin.com/in/thomas-breindl/', external: true },
            { label: 'GitHub', href: 'https://github.com/Aquitano', external: true },
            { label: 'Twitter / X', href: 'https://x.com/breindlthomas', external: true },
        ],
    },
];
---

<footer class="relative z-10 mt-(--space-section) w-full" role="contentinfo">
    <div class="w-full px-(--gutter) py-12 lg:py-16">
        <nav aria-label="Footer Navigation">
            <div class="grid gap-8 sm:grid-cols-2 sm:gap-10 lg:gap-16">
                {
                    sections.map((section) => (
                        <div>
                            <p class="text-lg font-bold tracking-tight text-(--text-primary) sm:text-xl md:text-2xl">
                                {section.title}
                            </p>
                            <div class="mb-2 h-0.5 w-full bg-(--border-default)" role="presentation" />
                            <ul class="mt-5 space-y-3" role="list">
                                {section.items.map((item) => (
                                    <li>
                                        <a
                                            href={item.href}
                                            {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                                            class="group inline-flex items-center gap-1.5 text-(length:--text-base) font-semibold text-(--text-secondary) transition-colors duration-(--duration-fast) hover:text-(--color-accent) sm:text-(length:--text-lg) md:text-(length:--text-xl)"
                                        >
                                            <span class="bg-linear-to-r from-(--color-accent) to-(--color-accent) bg-size-[0%_2px] bg-bottom-left bg-no-repeat transition-[background-size] duration-(--duration-normal) ease-out group-hover:bg-size-[100%_2px]">
                                                {item.label}
                                            </span>
                                            {item.external && (
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    viewBox="0 0 20 20"
                                                    fill="currentColor"
                                                    class="h-4 w-4 opacity-50"
                                                    aria-hidden="true"
                                                >
                                                    <path
                                                        fill-rule="evenodd"
                                                        d="M4.25 5.5a.75.75 0 0 0-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 0 0 .75-.75v-4a.75.75 0 0 1 1.5 0v4A2.25 2.25 0 0 1 12.75 17h-8.5A2.25 2.25 0 0 1 2 14.75v-8.5A2.25 2.25 0 0 1 4.25 4h5a.75.75 0 0 1 0 1.5h-5Z"
                                                        clip-rule="evenodd"
                                                    />
                                                    <path
                                                        fill-rule="evenodd"
                                                        d="M6.194 12.753a.75.75 0 0 0 1.06.053L16.5 4.44v2.81a.75.75 0 0 0 1.5 0v-4.5a.75.75 0 0 0-.75-.75h-4.5a.75.75 0 0 0 0 1.5h2.553l-9.056 8.194a.75.75 0 0 0-.053 1.06Z"
                                                        clip-rule="evenodd"
                                                    />
                                                </svg>
                                            )}
                                            {item.external && <span class="sr-only">(öffnet in neuem Tab)</span>}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </nav>

        <div class="mt-16 grid grid-cols-1 items-end gap-10 sm:mt-20 lg:grid-cols-2">
            <p
                class="text-(length:--text-4xl) leading-tight font-extrabold tracking-(--tracking-tight) text-(--text-primary) sm:text-(length:--text-5xl) lg:text-(length:--text-6xl)"
            >
                &copy; {year} Thomas Breindl
                <br class="hidden md:block" />
                All rights reserved.
            </p>
            <div class="justify-self-start text-(--text-secondary) md:justify-self-end">
                <p class="text-(length:--text-xs) font-bold tracking-widest text-(--text-tertiary) uppercase">
                    Local time
                </p>
                <time
                    id="local-time"
                    class="mt-2 block font-mono text-(length:--text-lg) font-semibold tabular-nums sm:text-(length:--text-xl)"
                    aria-live="off"
                    aria-label="Current local time"
                >
                    --:--:-- --
                </time>
            </div>
        </div>
    </div>
</footer>

<script>
    let intervalId: number | undefined;

    function mountClock() {
        const localTime = document.getElementById('local-time');
        if (!localTime) return;

        function updateTime() {
            if (!localTime) return;
            try {
                const now = new Date();
                const formatter = new Intl.DateTimeFormat(undefined, {
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    hour12: true,
                    timeZoneName: 'short',
                    timeZone: Intl.DateTimeFormat().resolvedOptions().timeZone,
                });
                localTime.textContent = formatter.format(now);
                localTime.setAttribute('datetime', now.toISOString());
            } catch {
                localTime.textContent = new Date().toLocaleTimeString();
            }
        }

        updateTime();
        if (intervalId) clearInterval(intervalId);
        intervalId = window.setInterval(updateTime, 1000);
    }

    function cleanupClock() {
        if (intervalId) {
            clearInterval(intervalId);
            intervalId = undefined;
        }
    }

    document.addEventListener('DOMContentLoaded', mountClock);
    document.addEventListener('astro:after-swap', mountClock);
    document.addEventListener('astro:before-swap', cleanupClock);
    mountClock();
</script>
