---
import Layout from '../layouts/Layout.astro';

interface ExperienceEntry {
    role: string;
    company: string;
    period: string;
    highlights: string[];
}

interface SkillGroup {
    title: string;
    items: string[];
}

const experiences: ExperienceEntry[] = [
    {
        role: 'Software Development Intern & Working Student',
        company: 'itestra GmbH',
        period: 'Mar 2025 - Present',
        highlights: [
            'Migrated ~12K LOC COBOL contract logic to Java/Quarkus, reducing codebase by 40%',
            'Validated multi-stage batch workflows (JBeret, Panache, Hibernate) for consistent outputs',
        ],
    },
    {
        role: 'Software Engineering Intern',
        company: 'CHECK24 Vergleichsportal GmbH',
        period: 'Aug 2025 - Sep 2025',
        highlights: [
            'Designed async ActiveMQ pipeline decoupling critical provider responses',
            'Cut P95 latency to ~150ms at 1.5M events/day with new Grafana metrics',
        ],
    },
    {
        role: 'Software Development Intern',
        company: '4process AG',
        period: 'Jul 2024 - Aug 2024',
        highlights: [
            'Built internal idea portal with SAP Fiori Elements for structured proposals',
            'Implemented Java tool for SAP Sales Cloud with >5k validated Excel updates/sec',
        ],
    },
];

const skillGroups: SkillGroup[] = [
    {
        title: 'Backend',
        items: ['Java', 'Spring Boot', 'Quarkus', 'JPA/Hibernate', 'Node.js', 'Python', 'SQL'],
    },
    {
        title: 'Frontend',
        items: ['TypeScript', 'React', 'Next.js', 'SolidJS', 'Astro', 'Tailwind'],
    },
    {
        title: 'Infrastructure',
        items: ['Docker', 'Kubernetes', 'Terraform', 'GitHub Actions', 'Grafana', 'PostgreSQL'],
    },
    {
        title: 'Self-Hosted',
        items: ['NixOS', 'Proxmox', 'Traefik', 'WireGuard', 'Ansible'],
    },
];

const coreSkills = [
    { name: 'Java', years: '3+' },
    { name: 'TypeScript', years: '4+' },
];

const languages = ['German (Native)', 'English (C1)', 'Latin'];
---

<Layout
    title="Timeline | Breindl Thomas"
    active="Über mich"
    SEO={{
        description:
            'Work experience, skills and tools - Thomas Breindl, Software Developer focused on Java, TypeScript and cloud technologies.',
        openGraph: {
            title: 'About - Thomas Breindl',
            type: 'website',
        },
    }}
>
    <div class="timeline-page">
        <section class="hero" aria-labelledby="page-title">
            <div class="hero-content">
                <div class="cli-header">
                    <span class="cli-prompt">$</span>
                    <span class="cli-command">ls -la ~/experience</span>
                </div>
                <span class="hero-tag">// About</span>
                <h1 id="page-title">Work Experience</h1>
                <p class="hero-sub">Building systems that scale</p>
            </div>
            <div class="hero-pattern" aria-hidden="true">
                <svg viewBox="0 0 400 200" preserveAspectRatio="none">
                    <defs>
                        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(0,0,0,0.04)" stroke-width="1"></path>
                        </pattern>
                    </defs>
                    <rect width="100%" height="100%" fill="url(#grid)"></rect>
                </svg>
            </div>
        </section>

        <section class="experience-section" aria-labelledby="experience-heading">
            <h2 id="experience-heading" class="sr-only">Professional Experience</h2>
            <div class="timeline-track" aria-hidden="true"></div>
            <ol class="experience-list" role="list">
                {
                    experiences.map((exp, index) => (
                        <li class="exp-card" style={`--card-index: ${index}`}>
                            <div class="exp-marker" aria-hidden="true">
                                <span class="marker-dot" />
                                <span class="marker-line" />
                            </div>
                            <article class="exp-content">
                                <header class="exp-header">
                                    <time class="exp-period">{exp.period}</time>
                                    <h3 class="exp-role">{exp.role}</h3>
                                    <p class="exp-company">{exp.company}</p>
                                </header>
                                <ul class="exp-highlights" aria-label="Key achievements">
                                    {exp.highlights.map((h) => (
                                        <li>
                                            <span class="highlight-arrow" aria-hidden="true">
                                                &rarr;
                                            </span>
                                            {h}
                                        </li>
                                    ))}
                                </ul>
                            </article>
                        </li>
                    ))
                }
            </ol>
        </section>

        <section class="skills-section" aria-labelledby="skills-heading">
            <header class="skills-header">
                <span class="section-tag">// Stack</span>
                <h2 id="skills-heading">Skills & Tools</h2>
            </header>

            <div class="core-stack">
                {
                    coreSkills.map((skill) => (
                        <div class="core-card" tabindex="0" role="button" aria-pressed="false">
                            <span class="core-name">{skill.name}</span>
                            <span class="core-years">{skill.years} years</span>
                        </div>
                    ))
                }
            </div>

            <div class="skill-grid" role="list">
                {
                    skillGroups.map((group) => (
                        <article class="skill-card" role="listitem">
                            <h3 class="skill-title">{group.title}</h3>
                            <ul class="skill-tags">
                                {group.items.map((item) => (
                                    <li class="skill-tag">{item}</li>
                                ))}
                            </ul>
                        </article>
                    ))
                }
            </div>

            <div class="lang-section">
                <h3 class="lang-title">Languages</h3>
                <ul class="lang-list">
                    {
                        languages.map((lang) => (
                            <li class="lang-item">
                                <p class="text-md">{lang}</p>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </section>
    </div>
</Layout>

<style>
    .timeline-page {
        padding-top: var(--space-12);
        padding-bottom: var(--space-section);
    }

    .hero {
        position: relative;
        padding: var(--space-section) var(--gutter);
        overflow: hidden;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        max-width: var(--container-6xl);
        margin: 0 auto;
    }

    /* CLI header */
    .cli-header {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        margin-bottom: var(--space-6);
        color: var(--text-secondary);
    }

    .cli-prompt {
        color: var(--color-accent);
        font-weight: var(--font-bold);
    }

    .cli-command {
        color: var(--text-secondary);
    }

    .hero-tag {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-md);
        color: var(--color-accent);
        letter-spacing: var(--tracking-wide);
        margin-bottom: var(--space-4);
    }

    .hero h1 {
        font-size: var(--text-6xl);
        font-weight: var(--font-black);
        letter-spacing: var(--tracking-tight);
        line-height: var(--leading-none);
        margin-bottom: var(--space-4);
        color: var(--text-primary);
    }

    .hero-sub {
        font-family: var(--font-mono);
        font-size: var(--text-lg);
        color: var(--text-secondary);
    }

    .hero-pattern {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    .hero-pattern svg {
        width: 100%;
        height: 100%;
    }

    .experience-section {
        position: relative;
        max-width: var(--container-6xl);
        margin: 0 auto;
        padding: 0 var(--gutter);
        padding-bottom: var(--space-section);
    }

    .timeline-track {
        position: absolute;
        left: calc(var(--gutter) + 6px);
        top: 0;
        bottom: 0;
        width: 1px;
        background: linear-gradient(
            to bottom,
            transparent 0%,
            var(--border-strong) 10%,
            var(--border-strong) 90%,
            transparent 100%
        );
    }

    @media (min-width: 768px) {
        .timeline-track {
            left: calc(var(--gutter) + 8px);
        }
    }

    .experience-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-10);
    }

    .exp-card {
        display: grid;
        grid-template-columns: 16px 1fr;
        gap: var(--space-6);
        opacity: 0;
        transform: translateY(20px);
        transition:
            opacity var(--duration-slow) var(--ease-out),
            transform var(--duration-slow) var(--ease-out);
        transition-delay: calc(var(--card-index) * 100ms);
    }

    .exp-card.is-visible {
        opacity: 1;
        transform: translateY(0);
    }

    .exp-marker {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: var(--space-1);
    }

    .marker-dot {
        width: 12px;
        height: 12px;
        border-radius: var(--radius-full);
        background: var(--bg-primary);
        border: 2px solid var(--color-accent);
        transition:
            border-color var(--duration-fast) var(--ease-out),
            background var(--duration-fast) var(--ease-out);
    }

    .exp-card:hover .marker-dot,
    .exp-card:focus-within .marker-dot {
        border-color: var(--color-accent);
        background: var(--color-accent);
    }

    .marker-line {
        flex: 1;
        width: 1px;
        background: var(--border-strong);
        margin-top: var(--space-2);
    }

    .exp-content {
        background: var(--bg-card);
        border: 1px solid var(--bg-card-border);
        border-radius: var(--radius-lg);
        padding: var(--space-6);
        position: relative;
        overflow: hidden;
        transition: border-color var(--duration-fast) var(--ease-out);
    }

    .exp-content::before {
        content: '////////////////////';
        position: absolute;
        top: 0;
        right: 0;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.15);
        letter-spacing: -0.05em;
        padding: var(--space-2) var(--space-3);
        pointer-events: none;
    }

    .exp-card:hover .exp-content,
    .exp-card:focus-within .exp-content {
        border-color: var(--bg-card-border-hover);
    }

    .exp-header {
        margin-bottom: var(--space-5);
    }

    .exp-period {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-accent);
        letter-spacing: var(--tracking-wider);
        text-transform: uppercase;
        margin-bottom: var(--space-2);
    }

    .exp-role {
        font-size: var(--text-xl);
        font-weight: var(--font-bold);
        color: var(--text-inverse);
        margin-bottom: var(--space-1);
        line-height: var(--leading-snug);
    }

    .exp-company {
        font-size: var(--text-sm);
        color: rgba(255, 255, 255, 0.6);
    }

    .exp-highlights {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .exp-highlights li {
        display: flex;
        gap: var(--space-3);
        font-size: var(--text-sm);
        color: rgba(255, 255, 255, 0.7);
        line-height: var(--leading-relaxed);
    }

    .highlight-arrow {
        flex-shrink: 0;
        font-family: var(--font-mono);
        color: var(--color-accent);
    }

    .skills-section {
        max-width: var(--container-6xl);
        margin: 0 auto;
        padding: 0 var(--gutter);
    }

    .skills-header {
        margin-bottom: var(--space-component);
    }

    .section-tag {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-md);
        color: var(--color-accent);
        letter-spacing: var(--tracking-wide);
        margin-bottom: var(--space-3);
    }

    .skills-header h2 {
        font-size: var(--text-4xl);
        font-weight: var(--font-black);
        letter-spacing: var(--tracking-tight);
        color: var(--text-primary);
    }

    .core-stack {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-4);
        margin-bottom: var(--space-10);
        max-width: 400px;
    }

    .core-card {
        padding: var(--space-6) var(--space-5);
        background: var(--bg-card);
        border: 1px solid var(--bg-card-border);
        border-radius: var(--radius-lg);
        text-align: center;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition:
            border-color var(--duration-fast) var(--ease-out),
            transform var(--duration-fast) var(--ease-out);
    }

    .core-card::before {
        content: '$$$$$';
        position: absolute;
        top: var(--space-2);
        left: var(--space-3);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.15);
        letter-spacing: 0.1em;
        pointer-events: none;
    }

    .core-card:hover,
    .core-card:focus-visible {
        border-color: var(--color-accent);
        transform: translateY(-2px);
    }

    .core-card:focus-visible {
        outline: var(--focus-ring-width) solid var(--focus-ring-color);
        outline-offset: var(--focus-ring-offset);
    }

    .core-name {
        display: block;
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
        font-weight: var(--font-bold);
        color: var(--color-accent);
        margin-bottom: var(--space-2);
    }

    .core-years {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.6);
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
    }

    .skill-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: var(--space-5);
        margin-bottom: var(--space-10);
    }

    .skill-card {
        background: var(--bg-card);
        border: 1px solid var(--bg-card-border);
        border-radius: var(--radius-lg);
        padding: var(--space-5);
        position: relative;
        overflow: hidden;
        transition: border-color var(--duration-fast) var(--ease-out);
    }

    .skill-card::before {
        content: '>>>>';
        position: absolute;
        top: var(--space-2);
        right: var(--space-3);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.15);
        letter-spacing: 0.05em;
        pointer-events: none;
    }

    .skill-card:hover {
        border-color: var(--bg-card-border-hover);
    }

    .skill-title {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: var(--font-medium);
        color: var(--color-accent);
        text-transform: uppercase;
        letter-spacing: var(--tracking-caps);
        margin-bottom: var(--space-4);
    }

    .skill-tags {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }

    .skill-tag {
        padding: var(--space-1) var(--space-3);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.8);
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: var(--radius-sm);
        transition:
            border-color var(--duration-fast) var(--ease-out),
            color var(--duration-fast) var(--ease-out);
    }

    .skill-tag:hover {
        border-color: var(--color-accent);
        color: var(--text-inverse);
    }

    .lang-section {
        padding-top: var(--space-8);
        border-top: 1px solid var(--border-default);
    }

    .lang-title {
        font-family: var(--font-mono);
        font-size: var(--text-lg);
        font-weight: var(--font-medium);
        color: var(--color-accent);
        text-transform: uppercase;
        letter-spacing: var(--tracking-caps);
        margin-bottom: var(--space-4);
    }

    .lang-list {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-6);
    }

    .lang-item {
        font-size: var(--text-sm);
        color: var(--text-secondary);
    }

    @media (prefers-reduced-motion: reduce) {
        .exp-card {
            opacity: 1;
            transform: none;
            transition: none;
        }

        .core-card,
        .skill-card,
        .skill-tag,
        .exp-content,
        .marker-dot {
            transition: none;
        }
    }

    @media (min-width: 768px) {
        .exp-card {
            grid-template-columns: 20px 1fr;
        }

        .marker-dot {
            width: 16px;
            height: 16px;
        }
    }

    @media (min-width: 1024px) {
        .skill-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }
</style>

<script>
    function initTimeline() {
        const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const cards = document.querySelectorAll<HTMLElement>('.exp-card');

        if (prefersReduce || !('IntersectionObserver' in window)) {
            cards.forEach((card) => card.classList.add('is-visible'));
            return;
        }

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        (entry.target as HTMLElement).classList.add('is-visible');
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.1, rootMargin: '0px 0px -10% 0px' },
        );

        cards.forEach((card) => observer.observe(card));
    }

    initTimeline();
    document.addEventListener('astro:page-load', initTimeline);
    document.addEventListener('astro:after-swap', initTimeline);
</script>
