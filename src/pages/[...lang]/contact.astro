---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import { defaultLang, type Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
    return [{ params: { lang: undefined } }, { params: { lang: 'en' } }];
}

const lang: Lang = Astro.params.lang === 'en' ? 'en' : defaultLang;
const t = useTranslations(lang);
---

<Layout
    title={t('seo.contactTitle')}
    active="contact"
    lang={lang}
    SEO={{
        description: t('seo.contactDesc'),
        openGraph: {
            title: t('seo.contactTitle'),
            type: 'website',
        },
    }}
>
    <section class="contact-page">
        <div class="mx-auto w-full max-w-6xl">
            <div class="contact-header">
                <span class="section-tag">// Contact</span>
                <h1>{t('contact.title')}</h1>
                <p class="contact-subtitle">{t('contact.subtitle')}</p>
            </div>
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-12">
                <div class="contact-card">
                    <div class="card-ascii" aria-hidden="true">$$$$$</div>
                    <h2 class="card-title">{t('contact.details')}</h2>

                    <address class="contact-list not-italic">
                        <div class="contact-item">
                            <div class="contact-icon" aria-hidden="true">
                                <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" class="h-5 w-5">
                                    <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                    <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="contact-label">{t('contact.location')}</p>
                                <p class="contact-value">{t('contact.locationValue')}</p>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon" aria-hidden="true">
                                <Icon name="mdi:twitter" class="h-5 w-5" />
                            </div>
                            <div>
                                <p class="contact-label">Twitter / X</p>
                                <a href="https://twitter.com/BreindlThomas" target="_blank" rel="noopener noreferrer" class="contact-link">
                                    @BreindlThomas
                                </a>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon" aria-hidden="true">
                                <Icon name="mdi:github" class="h-5 w-5" />
                            </div>
                            <div>
                                <p class="contact-label">GitHub</p>
                                <a href="https://github.com/Aquitano" target="_blank" rel="noopener noreferrer" class="contact-link">
                                    Aquitano
                                </a>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon" aria-hidden="true">
                                <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" class="h-5 w-5">
                                    <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="contact-label">{t('contact.email')}</p>
                                <a href="mailto:ThomasBreindl@proton.me" class="contact-link">
                                    ThomasBreindl@proton.me
                                </a>
                            </div>
                        </div>
                    </address>
                </div>

                <form
                    class="contact-card"
                    name="contact"
                    data-netlify-recaptcha="true"
                    data-netlify="true"
                    method="POST"
                    novalidate
                    aria-label={t('contact.form')}
                    data-lang={lang}
                >
                    <div class="card-ascii" aria-hidden="true">////</div>
                    <input type="hidden" name="form-name" value="contact" />

                    <div class="form-field">
                        <label for="name" class="form-label">
                            {t('contact.fullName')}
                            <span class="required" aria-hidden="true">*</span>
                        </label>
                        <input type="text" name="name" id="name" autocomplete="name" required aria-required="true" class="form-input" placeholder={t('contact.namePlaceholder')} />
                    </div>

                    <div class="form-field">
                        <label for="email" class="form-label">
                            {t('contact.email')}
                            <span class="required" aria-hidden="true">*</span>
                        </label>
                        <input type="email" name="email" id="email" autocomplete="email" required aria-required="true" aria-describedby="email-hint" class="form-input" placeholder={t('contact.emailPlaceholder')} />
                        <p id="email-hint" class="form-hint">{t('contact.emailHint')}</p>
                    </div>

                    <div class="form-field">
                        <label for="tel" class="form-label">
                            {t('contact.phone')}
                            <span class="required" aria-hidden="true">*</span>
                        </label>
                        <input type="tel" name="tel" id="tel" autocomplete="tel" required aria-required="true" class="form-input" placeholder={t('contact.phonePlaceholder')} />
                    </div>

                    <div class="form-field">
                        <label for="message" class="form-label">
                            {t('contact.message')}
                            <span class="required" aria-hidden="true">*</span>
                        </label>
                        <textarea name="message" id="message" required aria-required="true" rows="5" class="form-input form-textarea" placeholder={t('contact.messagePlaceholder')}></textarea>
                    </div>

                    <div data-netlify-recaptcha="true"></div>

                    <div id="form-error" role="alert" aria-live="polite" class="form-message form-error hidden"></div>
                    <div id="form-success" role="status" aria-live="polite" class="form-message form-success hidden"></div>

                    <button type="submit" class="btn btn-primary submit-btn">
                        {t('contact.submit')}
                        <span class="btn-arrow" aria-hidden="true">&rarr;</span>
                    </button>
                </form>
            </div>
        </div>
    </section>
</Layout>

<script>
    import { ui, defaultLang, type Lang, type TranslationKey } from '../../i18n/ui';

    function getFormLang(): Lang {
        const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
        const lang = form?.dataset.lang as Lang | undefined;
        return lang && lang in ui ? lang : defaultLang;
    }

    function ft(key: TranslationKey): string {
        const lang = getFormLang();
        return ui[lang][key] ?? ui[defaultLang][key];
    }

    function initContactForm() {
        const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
        const errorContainer = document.getElementById('form-error');
        const successContainer = document.getElementById('form-success');

        if (!form || !errorContainer || !successContainer) return;
        if (form.dataset.contactInitialized === 'true') return;

        function showError(message: string) {
            if (!errorContainer || !successContainer) return;
            errorContainer.textContent = message;
            errorContainer.classList.remove('hidden');
            successContainer.classList.add('hidden');
        }

        function showSuccess(message: string) {
            if (!errorContainer || !successContainer) return;
            successContainer.textContent = message;
            successContainer.classList.remove('hidden');
            errorContainer.classList.add('hidden');
        }

        function hideMessages() {
            if (!errorContainer || !successContainer) return;
            errorContainer.classList.add('hidden');
            successContainer.classList.add('hidden');
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideMessages();

            const nameInput = form.querySelector<HTMLInputElement>('#name');
            const emailInput = form.querySelector<HTMLInputElement>('#email');
            const telInput = form.querySelector<HTMLInputElement>('#tel');
            const messageInput = form.querySelector<HTMLTextAreaElement>('#message');

            const name = nameInput?.value.trim() ?? '';
            const email = emailInput?.value.trim() ?? '';
            const tel = telInput?.value.replace(/\s/g, '') ?? '';
            const message = messageInput?.value.trim() ?? '';

            if (!name || !email || !tel || !message) {
                showError(ft('contact.errorRequired'));
                return;
            }

            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                showError(ft('contact.errorEmail'));
                emailInput?.focus();
                return;
            }

            if (!/^[0-9\-+]{9,15}$/.test(tel)) {
                showError(ft('contact.errorPhone'));
                telInput?.focus();
                return;
            }

            const formData = new FormData(form);
            formData.set('name', name);
            formData.set('email', email);
            formData.set('tel', tel);
            formData.set('message', message);

            const body = new URLSearchParams();
            formData.forEach((value, key) => {
                body.append(key, typeof value === 'string' ? value : value.name);
            });

            try {
                const response = await fetch('/', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body.toString(),
                });

                if (response.ok) {
                    showSuccess(ft('contact.success'));
                    form.reset();
                } else {
                    showError(ft('contact.errorSend'));
                }
            } catch {
                showError(ft('contact.errorNetwork'));
            }
        });

        form.dataset.contactInitialized = 'true';
    }

    document.addEventListener('DOMContentLoaded', initContactForm);
    document.addEventListener('astro:after-swap', initContactForm);
    initContactForm();
</script>

<style>
    @reference "../../styles/global.css";

    .contact-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: var(--space-section) var(--gutter);
    }

    .contact-header {
        text-align: center;
        margin-bottom: var(--space-component);
    }

    .contact-header h1 {
        @apply font-display text-5xl tracking-tight;
        font-weight: 900;
        @apply text-text-primary;
        margin-bottom: 1rem;
    }

    .contact-subtitle {
        @apply text-lg;
        @apply text-text-secondary;
    }

    .contact-card {
        background: var(--bg-card);
        border: 1px solid var(--bg-card-border);
        border-radius: 0.75rem;
        padding: 2rem;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .card-ascii {
        position: absolute;
        top: 0.75rem;
        right: 1rem;
        @apply font-mono text-xs tracking-wider;
        color: rgba(255, 255, 255, 0.15);
        pointer-events: none;
        user-select: none;
    }

    .card-title {
        @apply font-mono text-xs tracking-caps;
        font-weight: 500;
        color: var(--color-accent);
        text-transform: uppercase;
    }

    .contact-list {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .contact-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .contact-icon {
        flex-shrink: 0;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(224, 122, 58, 0.15);
        border-radius: 0.375rem;
        color: var(--color-accent);
    }

    .contact-label {
        @apply font-mono text-xs tracking-wider;
        color: rgba(255, 255, 255, 0.6);
        text-transform: uppercase;
        margin-bottom: 0.25rem;
    }

    .contact-value {
        @apply text-base;
        @apply text-text-inverse;
        font-weight: 600;
    }

    .contact-link {
        @apply text-base;
        @apply text-text-inverse;
        font-weight: 600;
        text-decoration: underline;
        text-decoration-color: rgba(255, 255, 255, 0.3);
        text-underline-offset: 2px;
        transition:
            color var(--duration-fast) var(--ease-out),
            text-decoration-color var(--duration-fast) var(--ease-out);
    }

    .contact-link:hover {
        color: var(--color-accent);
        text-decoration-color: var(--color-accent);
    }

    .form-field {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        @apply font-mono text-xs tracking-wider;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
        text-transform: uppercase;
    }

    .required {
        color: var(--color-accent);
    }

    .form-input {
        width: 100%;
        padding: 0.75rem 1rem;
        @apply text-base;
        @apply text-text-inverse;
        font-weight: 500;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 0.375rem;
        transition: border-color var(--duration-fast) var(--ease-out);
    }

    .form-input::placeholder {
        color: rgba(255, 255, 255, 0.4);
    }

    .form-input:hover {
        border-color: rgba(255, 255, 255, 0.25);
    }

    .form-input:focus {
        border-color: var(--color-accent);
        outline: none;
    }

    .form-textarea {
        min-height: 120px;
        resize: vertical;
    }

    .form-hint {
        @apply text-xs;
        color: rgba(255, 255, 255, 0.5);
    }

    .form-message {
        padding: 1rem;
        border-radius: 0.375rem;
        @apply text-sm;
    }

    .form-error {
        background: rgba(255, 89, 89, 0.15);
        color: #ff5959;
    }

    .form-success {
        background: rgba(89, 255, 89, 0.15);
        color: #59ff59;
    }

    .submit-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        align-self: flex-start;
        padding: 0.75rem 1.5rem;
    }

    .btn-arrow {
        @apply font-mono;
        transition: transform var(--duration-fast) var(--ease-out);
    }

    .submit-btn:hover .btn-arrow {
        transform: translateX(4px);
    }

    .hidden {
        display: none;
    }
</style>
