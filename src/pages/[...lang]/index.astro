---
import { getCollection } from 'astro:content';
import HomeTop from '../../components/HomeTop.astro';
import Projects from '../../components/Projects.tsx';
import Layout from '../../layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { defaultLang, type Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
    return [{ params: { lang: undefined } }, { params: { lang: 'en' } }];
}

const lang: Lang = Astro.params.lang === 'en' ? 'en' : defaultLang;
const t = useTranslations(lang);

const allProjectsRaw = await getCollection('project');
const allProjects = lang === 'en'
    ? allProjectsRaw.filter((p) => p.slug.startsWith('en/')).map((p) => ({ ...p, slug: p.slug.replace(/^en\//, '') }))
    : allProjectsRaw.filter((p) => !p.slug.startsWith('en/'));
export type product = CollectionEntry<'project'>;
---

<Layout
    title={t('seo.homeTitle')}
    active="home"
    lang={lang}
    SEO={{
        description: t('seo.homeDesc'),
        openGraph: {
            title: t('seo.homeOgTitle'),
            type: 'website',
        },
    }}
>
    <div id="Welcome">
        <HomeTop lang={lang} />

        <Projects allProjects={allProjects} client:load lang={lang} />
    </div>
</Layout>

