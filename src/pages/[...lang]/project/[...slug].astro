---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { defaultLang, type Lang } from '../../../i18n/ui';
import { useTranslations, getLocalePath } from '../../../i18n/utils';

export async function getStaticPaths() {
    const projects = await getCollection('project');
    const deProjects = projects.filter((p) => !p.slug.startsWith('en/'));
    const enProjects = projects.filter((p) => p.slug.startsWith('en/'));

    return [
        ...deProjects.map((project) => ({
            params: { lang: undefined, slug: project.slug },
            props: { project },
        })),
        ...enProjects.map((project) => ({
            params: { lang: 'en', slug: project.slug.replace(/^en\//, '') },
            props: { project },
        })),
    ];
}

interface Props {
    project: CollectionEntry<'project'>;
}

const { project } = Astro.props;
const lang: Lang = Astro.params.lang === 'en' ? 'en' : defaultLang;
const t = useTranslations(lang);
const { Content } = await project.render();

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpg,jpeg,png,webp}');
const imagePath = `/src/assets/images/${project.data.fullImage}`;

let fullImageSrc: ImageMetadata | null = null;
if (project.data.fullImage) {
    if (!images[imagePath]) {
        console.warn(`Full image not found for ${imagePath}`);
    } else {
        const mod = await images[imagePath]();
        fullImageSrc = mod.default;
    }
}
---

<Layout
    title={`${project.data.title} | Thomas Breindl`}
    active="projects"
    lang={lang}
    SEO={{
        description: project.data.description,
        openGraph: {
            title: project.data.title,
            type: 'article',
            image: project.data.share?.image || `/images/${project.data.name}.webp`,
        },
        extend: {
            meta: {
                keywords: [...project.data.tags, ...project.data.tasks, project.data.name],
            },
        },
    }}
>
    <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'CreativeWork',
            name: project.data.title,
            description: project.data.description,
            creator: {
                '@type': 'Person',
                name: 'Thomas Breindl',
            },
            dateCreated: project.data.year.toString(),
            keywords: [...project.data.tags, ...project.data.tasks].join(', '),
            url: new URL(`/project/${project.slug}`, Astro.site).toString(),
        })}
    />

    <div class="project-page pb-(--space-section)">
        <article>
            <div class="project-glow" aria-hidden="true"></div>

            <section class="relative pt-14 md:pt-24 lg:pt-32" aria-labelledby="project-title">
                <div class="mx-auto max-w-6xl px-(--gutter)">
                    <nav class="hero-animation mb-10 opacity-0" aria-label={t('project.back')}>
                        <a
                            href={`${getLocalePath(lang, '/')}#portfolio`}
                            class="group/back inline-flex items-center gap-2 font-mono text-xs text-(--text-tertiary) transition-colors duration-200 hover:text-(--color-accent)"
                            data-astro-prefetch
                        >
                            <span class="transition-transform duration-200 group-hover/back:-translate-x-1">&larr;</span>
                            <span>cd ~/portfolio</span>
                        </a>
                    </nav>

                    <div class="relative mb-12 md:mb-16 lg:mb-20">
                        {
                            project.data.featured && (
                                <div class="hero-animation mb-6 flex items-center gap-3 opacity-0">
                                    <span class="font-mono text-(--color-accent)">{'['}</span>
                                    <span class="font-mono text-xs font-semibold tracking-wider text-(--color-accent) uppercase">
                                        {t('project.featured')}
                                    </span>
                                    <span class="font-mono text-(--color-accent)">{']'}</span>
                                    <div class="h-px flex-1 bg-linear-to-r from-[rgba(224,122,58,0.3)] to-transparent" />
                                </div>
                            )
                        }

                        <div class="hero-animation mb-8 opacity-0">
                            <div class="mb-3 font-mono text-sm text-(--text-tertiary)">
                                {'$ '}cat ./projects/{project.data.name.toLowerCase()}/README.md
                            </div>
                            <h1
                                id="project-title"
                                class="project-title font-display"
                            >
                                {project.data.title}
                            </h1>
                        </div>

                        <div class="hero-animation flex flex-wrap items-center gap-2.5 pt-4 opacity-0">
                            <span class="mr-1 hidden font-mono text-xs text-(--text-tertiary) sm:inline">{'$ '}tags --list</span>
                            <span class="mr-1 hidden font-mono text-xs text-(--text-muted) sm:inline">|</span>
                            {
                                project.data.tags.map((tag: string) => (
                                    <span class="chip">
                                        {tag}
                                    </span>
                                ))
                            }
                            <span class="rounded-sm bg-(--color-accent-muted) px-3.5 py-1.5 font-mono text-sm font-semibold text-(--color-accent) sm:ml-auto">
                                {project.data.year}
                            </span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1fr_380px] lg:gap-16">
                        <div>
                            <section class="hero-animation mb-8 opacity-0">
                                <div class="section-heading mb-6">
                                    <span class="font-mono text-xs text-(--color-accent)">{'>'}</span>
                                    <span class="font-mono text-xs font-semibold tracking-wider text-(--text-secondary) uppercase">
                                        {t('project.overview')}
                                    </span>
                                    <div class="section-heading-line"></div>
                                </div>
                                <div class="prose text-base leading-relaxed text-(--text-secondary)">
                                    <Content />
                                </div>
                            </section>
                        </div>

                        <div class="order-first lg:order-last">
                            <section class="hero-animation mb-8 opacity-0">
                                <div class="section-heading mb-4">
                                    <span class="font-mono text-xs text-(--color-accent)">{'>'}</span>
                                    <span class="font-mono text-xs font-semibold tracking-wider text-(--text-secondary) uppercase">
                                        {t('project.contributions')}
                                    </span>
                                    <div class="section-heading-line"></div>
                                </div>
                                <div class="tasks-card">
                                    <div class="tasks-card-header">
                                        <span>{'$ '}cat tasks.log</span>
                                        <span class="tasks-card-dots" aria-hidden="true">
                                            <span></span><span></span><span></span>
                                        </span>
                                    </div>
                                    <ul class="flex flex-col gap-3">
                                        {
                                            project.data.tasks.map((task: string, index: number) => (
                                                <li class="task-item">
                                                    <span class="task-index">
                                                        {String(index + 1).padStart(2, '0')}
                                                    </span>
                                                    <span class="task-arrow" aria-hidden="true">-></span>
                                                    <span class="task-text">
                                                        {task}
                                                    </span>
                                                </li>
                                            ))
                                        }
                                    </ul>
                                    <div class="tasks-card-footer">
                                        <span>exit code: 0</span>
                                        <span>{project.data.tasks.length} {t('project.tasksCompleted')}</span>
                                    </div>
                                </div>
                            </section>

                            {
                                project.data.links && project.data.links.length > 0 && (
                                    <section class="hero-animation mb-8 opacity-0">
                                        <div class="section-heading mb-4">
                                            <span class="font-mono text-xs text-(--color-accent)">{'>'}</span>
                                            <span class="font-mono text-xs font-semibold tracking-wider text-(--text-secondary) uppercase">
                                                {t('project.links')}
                                            </span>
                                            <div class="section-heading-line" />
                                        </div>
                                        <div class="flex flex-col gap-2.5">
                                            {project.data.links.map(
                                                (link: { text: string; icon: string; link: string }, index: number) => (
                                                    <a
                                                        href={link.link}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        class="link-card group/link"
                                                    >
                                                        <span class="link-card-index">
                                                            {String(index + 1).padStart(2, '0')}
                                                        </span>
                                                        <span class="link-card-text">
                                                            {link.text}
                                                        </span>
                                                        <span class="link-card-arrow">
                                                            ->
                                                        </span>
                                                    </a>
                                                ),
                                            )}
                                        </div>
                                        <div class="mt-3 font-mono text-xs text-white/25">{'$ '}open --external</div>
                                    </section>
                                )
                            }
                        </div>
                    </div>
                </div>
            </section>

            {
                fullImageSrc && (
                    <section class="hero-animation mt-16 opacity-0 md:mt-20" aria-label={t('project.image')}>
                        <div class="mx-auto max-w-6xl px-(--gutter)">
                            <div class="image-frame">
                                <figure class="m-0">
                                    <Image
                                        alt={`${project.data.title} – ${t('project.fullView')}`}
                                        src={fullImageSrc}
                                        height={820}
                                        width={1420}
                                        class="block h-auto w-full rounded-xl"
                                        loading="lazy"
                                    />
                                </figure>
                            </div>
                        </div>
                    </section>
                )
            }
        </article>
    </div>
</Layout>

<style>
    .project-page {
        position: relative;
        overflow: hidden;
    }

    .project-glow {
        position: absolute;
        top: -120px;
        left: 50%;
        transform: translateX(-50%);
        width: 800px;
        height: 400px;
        background: radial-gradient(ellipse at center, rgba(224, 122, 58, 0.08) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
    }

    .project-title {
        font-size: var(--text-5xl);
        font-weight: var(--font-black);
        line-height: var(--leading-none);
        letter-spacing: var(--tracking-tight);
        color: var(--text-primary);
        overflow-wrap: anywhere;
        text-wrap: balance;
    }

    .prose :global(p) {
        margin-bottom: var(--space-5);
    }

    .prose :global(strong) {
        font-weight: var(--font-semibold);
        color: var(--text-primary);
    }

    .hero-animation {
        opacity: 0;
        transition: none;
    }

    .group\/back:hover span:first-child {
        animation: arrow-bounce 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes arrow-bounce {
        0%, 100% { transform: translate3d(0, 0, 0); }
        30% { transform: translate3d(-6px, 0, 0); }
        60% { transform: translate3d(-2px, 0, 0); }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-animation {
            opacity: 1 !important;
        }

        .chip,
        .tasks-card,
        .link-card,
        .link-card-arrow,
        .link-card-text,
        .task-text {
            transition: none;
        }

        @keyframes arrow-bounce {
            0%, 100% { transform: none; }
        }
    }
</style>

<script>
    import { animate, type AnimationSequence } from 'motion';
    import { getMotionPreference } from '../../../utils/cliAnimations';

    const motionOK = getMotionPreference();

    let projectAnim: ReturnType<typeof animate> | null = null;

    function waitForLoader() {
        return new Promise<void>((resolve) => {
            const loader = document.querySelector<HTMLElement>('#loader');
            if (!loader || !loader.classList.contains('on')) {
                resolve();
                return;
            }

            const finish = () => {
                loader.removeEventListener('transitionend', finish);
                observer?.disconnect();
                resolve();
            };

            const observer = new MutationObserver(() => {
                if (!loader.classList.contains('on')) {
                    finish();
                }
            });

            loader.addEventListener('transitionend', finish, { once: true });
            observer.observe(loader, { attributes: true, attributeFilter: ['class'] });

            setTimeout(finish, 1200);
        });
    }

    function runProjectAnimations() {
        if (!document.querySelector('.project-page')) return;

        if (!motionOK) {
            const elements = document.querySelectorAll<HTMLElement>('.hero-animation');
            elements.forEach((el) => {
                el.style.opacity = '1';
            });
            return;
        }

        const animatedElements = document.querySelectorAll<HTMLElement>('.hero-animation');
        const sequence: AnimationSequence = [];

        animatedElements.forEach((el, index) => {
            const delay = 0.1 + index * 0.06;
            el.style.cssText = 'opacity:0; transform: translate3d(0,12px,0)';
            sequence.push([
                el,
                {
                    opacity: [0, 1],
                    y: [12, 0],
                },
                { at: delay, duration: 0.6, ease: [0.16, 1, 0.3, 1] },
            ]);
        });

        if (sequence.length) {
            projectAnim?.stop();
            projectAnim = animate(sequence as any);

            projectAnim.finished.then(() => {
                animatedElements.forEach((el) => {
                    el.style.transform = '';
                    el.style.willChange = 'auto';
                });
            });
        }
    }

    let animationRunId = 0;
    document.addEventListener('astro:page-load', async () => {
        const runId = ++animationRunId;
        await waitForLoader();
        if (runId !== animationRunId) return;
        runProjectAnimations();
    });
    document.addEventListener('astro:before-swap', () => {
        projectAnim?.stop();
        projectAnim = null;
    });
</script>
