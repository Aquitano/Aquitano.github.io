---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import LinkButton from '../../components/LinkButton.astro';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    const projects = await getCollection('project');
    return projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

interface Props {
    project: CollectionEntry<'project'>;
}

const { project } = Astro.props;
const { Content } = await project.render();

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpg,jpeg,png,webp}');
const imagePath = `/src/assets/images/${project.data.fullImage}`;

let fullImageSrc: ImageMetadata | null = null;
if (project.data.fullImage) {
    if (!images[imagePath]) {
        console.warn(`Full image not found for ${imagePath}`);
    } else {
        const mod = await images[imagePath]();
        fullImageSrc = mod.default;
    }
}
---

<Layout
    title={`${project.data.title} | Breindl Thomas`}
    active="Projekte"
    SEO={{
        description: project.data.description,
        openGraph: {
            title: project.data.title,
            type: 'article',
            image: project.data.share?.image || `/images/${project.data.name}.webp`,
        },
        extend: {
            meta: {
                keywords: [...project.data.tags, ...project.data.tasks, project.data.name],
            },
        },
    }}
>
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'CreativeWork',
            name: project.data.title,
            description: project.data.description,
            creator: {
                '@type': 'Person',
                name: 'Thomas Breindl',
            },
            dateCreated: project.data.year.toString(),
            keywords: [...project.data.tags, ...project.data.tasks].join(', '),
            url: new URL(`/project/${project.slug}`, Astro.site).toString(),
        })}
    />

    <div class="scroll-container">
        <article>
            <section class="project-hero pt-24 md:pt-36 lg:pt-48 xl:pt-52" aria-labelledby="project-title">
                <div class="wrapper px-[var(--gutter)]">
                    <!-- CLI-style header -->
                    <div class="cli-header hero-animation">
                        <span class="cli-prompt">$</span>
                        <span class="cli-command">cat project/{project.data.name}.md</span>
                    </div>

                    <!-- Title -->
                    <h1 id="project-title" class="project-title hero-animation">
                        {project.data.title}
                    </h1>

                    <div class="grid grid-cols-1 gap-6 md:gap-8 md:grid-cols-3">
                        <!-- Project Meta Sidebar -->
                        <aside class="info mb-5 md:mb-0">
                            <div class="meta-card hero-animation">
                                <!-- ASCII decoration -->
                                <div class="card-decoration-top" aria-hidden="true">
                                    >>>
                                </div>
                                
                                <div id="Desc" class="meta-content">
                                    <div class="meta-section">
                                        <p class="pre-header">
                                            Aufgabe
                                        </p>
                                        <div class="meta-list">
                                            {project.data.tasks.map((task: string) => (
                                                <div class="meta-item">
                                                    <span class="meta-arrow" aria-hidden="true">→</span>
                                                    <span class="meta-text">{task}</span>
                                                </div>
                                            ))}
                                        </div>
                                    </div>

                                    <div class="meta-section">
                                        <p class="pre-header">
                                            Jahr
                                        </p>
                                        <p class="meta-value">
                                            {project.data.year}
                                        </p>
                                    </div>
                                </div>

                                <!-- Halftone decoration -->
                                <div class="halftone-decoration" aria-hidden="true"></div>
                            </div>
                        </aside>

                        <!-- Project Content -->
                        <div class="content col-span-2">
                            <div class="content-card hero-animation">
                                <!-- Content header decoration -->
                                <div class="card-decoration-top" aria-hidden="true">
                                    /////
                                </div>

                                <div class="content-body prose">
                                    <Content />
                                    
                                    {project.data.links && project.data.links.length > 0 && (
                                        <nav class="links-section" aria-label="Projektlinks">
                                            {project.data.links.map((link: { text: string; icon: string; link: string }) => (
                                                <LinkButton text={link.text} icon={link.icon} href={link.link} />
                                            ))}
                                        </nav>
                                    )}
                                </div>

                                <!-- Halftone decoration -->
                                <div class="halftone-decoration" aria-hidden="true"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            {fullImageSrc && (
                <section class="case-study-photos hero-animation pt-20" aria-label="Projektbild">
                    <div class="wrapper px-[var(--gutter)]">
                        <figure>
                            <Image
                                alt={`${project.data.title} - Vollständige Projektansicht`}
                                src={fullImageSrc}
                                height={820}
                                width={1420}
                                class="rounded-3xl"
                                loading="lazy"
                            />
                        </figure>
                    </div>
                </section>
            )}
        </article>
    </div>
</Layout>

<style>
    .scroll-container {
        padding-bottom: var(--space-section);
    }

    .wrapper {
        max-width: var(--container-6xl);
        margin: 0 auto;
    }

    .project-hero {
        position: relative;
    }

    .project-hero::before {
        content: '';
        position: absolute;
        inset: -40px 0 0;
        pointer-events: none;
        background: radial-gradient(900px 180px at 50% 0, var(--color-accent-muted), transparent 70%);
    }

    /* CLI Header */
    .cli-header {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        margin-bottom: var(--space-8);
        color: var(--text-secondary);
    }

    .cli-prompt {
        color: var(--color-accent);
        font-weight: var(--font-bold);
    }

    .cli-command {
        color: var(--text-secondary);
    }

    /* Title */
    .project-title {
        font-family: var(--font-display);
        font-size: clamp(2rem, 1rem + 4.5vw, 5rem);
        line-height: var(--leading-tight);
        letter-spacing: var(--tracking-tight);
        text-wrap: balance;
        font-weight: var(--font-black);
        color: var(--text-primary);
        word-break: break-word;
        overflow-wrap: break-word;
        hyphens: auto;
        margin-bottom: var(--space-8);
    }

    /* Card Decorations */
    .card-decoration-top {
        position: absolute;
        top: var(--space-3);
        right: var(--space-4);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.15);
        letter-spacing: 0.05em;
        pointer-events: none;
        user-select: none;
    }

    .halftone-decoration {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: repeating-linear-gradient(
            90deg,
            rgba(224, 122, 58, 0.3) 0,
            rgba(224, 122, 58, 0.3) 2px,
            transparent 2px,
            transparent 6px
        );
        pointer-events: none;
    }

    /* Meta Card */
    .meta-card {
        position: relative;
        background: var(--bg-card);
        border: 1px solid var(--bg-card-border);
        border-radius: var(--radius-lg);
        padding: var(--space-6);
        overflow: hidden;
        transition: border-color var(--duration-fast) var(--ease-out);
    }

    .meta-card:hover {
        border-color: var(--bg-card-border-hover);
    }

    .meta-content {
        position: relative;
    }

    .meta-section {
        margin-bottom: var(--space-6);
    }

    .meta-section:last-child {
        margin-bottom: 0;
    }

    .pre-header {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: var(--font-semibold);
        color: var(--color-accent);
        text-transform: uppercase;
        letter-spacing: var(--tracking-caps);
        margin-bottom: var(--space-3);
    }

    .meta-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .meta-item {
        display: flex;
        align-items: flex-start;
        gap: var(--space-3);
        font-size: var(--text-sm);
        font-weight: var(--font-medium);
        color: rgba(255, 255, 255, 0.8);
        line-height: var(--leading-relaxed);
    }

    .meta-arrow {
        font-family: var(--font-mono);
        color: var(--color-accent);
        flex-shrink: 0;
        margin-top: 0.125em;
    }

    .meta-text {
        flex: 1;
        word-break: break-word;
        overflow-wrap: break-word;
    }

    .meta-value {
        font-size: var(--text-lg);
        font-weight: var(--font-bold);
        color: var(--text-inverse);
        font-family: var(--font-mono);
    }

    /* Content Card */
    .content-card {
        position: relative;
        background: var(--bg-card);
        border: 1px solid var(--bg-card-border);
        border-radius: var(--radius-lg);
        padding: var(--space-6);
        overflow: hidden;
        transition: border-color var(--duration-fast) var(--ease-out);
    }

    .content-card:hover {
        border-color: var(--bg-card-border-hover);
    }

    .content-body {
        font-size: var(--text-base);
        line-height: var(--leading-relaxed);
        color: rgba(255, 255, 255, 0.8);
        text-wrap: pretty;
    }

    .content-body :global(p) {
        font-size: var(--text-base);
        line-height: var(--leading-relaxed);
        margin-bottom: var(--space-5);
        color: rgba(255, 255, 255, 0.8);
    }

    .content-body :global(strong) {
        font-weight: var(--font-semibold);
        color: var(--text-inverse);
    }

    /* Links Section */
    .links-section {
        margin-top: var(--space-8);
        padding-top: var(--space-6);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-4);
    }

    /* Image Section */
    .case-study-photos figure {
        margin: 0;
    }

    .case-study-photos :global(img) {
        display: block;
        max-width: 100%;
        opacity: 1;
        margin: 0 auto;
        width: 100%;
    }

    /* Animations */
    .hero-animation {
        opacity: 0;
        transition: none;
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-animation {
            opacity: 1 !important;
        }
    }

    /* Responsive adjustments */
    @media (max-width: 767px) {
        .project-title {
            font-size: clamp(1.75rem, 0.9rem + 3.5vw, 3.5rem);
        }
        
        .cli-header {
            margin-bottom: var(--space-6);
        }
    }
</style>

<script>
    import { animate } from 'motion';

    const motionOK = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

    const DELAY_CLI = 0.2;
    const DELAY_TITLE = 0.4;
    const DELAY_META = 0.6;
    const DELAY_CONTENT = 0.7;
    const DELAY_PHOTO = 0.9;

    let projectAnim: ReturnType<typeof animate> | null = null;

    function runProjectAnimations() {
        if (!motionOK) {
            const elements = document.querySelectorAll<HTMLElement>('.hero-animation');
            elements.forEach((el) => {
                el.style.opacity = '1';
            });
            return;
        }

        const cli = document.querySelector<HTMLElement>('.cli-header');
        const title = document.querySelector<HTMLElement>('.project-title');
        const meta = document.querySelector<HTMLElement>('.meta-card');
        const content = document.querySelector<HTMLElement>('.content-card');
        const photo = document.querySelector<HTMLElement>('.case-study-photos');

        const sequence: Parameters<typeof animate>[0] = [];

        if (cli) {
            cli.style.cssText = 'opacity:0; transform: translate3d(-8px,0,0)';
            sequence.push([
                cli,
                {
                    opacity: [0, 1],
                    x: [-8, 0],
                },
                { at: DELAY_CLI, duration: 0.6, ease: 'easeOut' },
            ]);
        }

        if (title) {
            title.style.cssText = 'opacity:0; transform: translate3d(0,16px,0)';
            sequence.push([
                title,
                {
                    opacity: [0, 1],
                    y: [16, 0],
                },
                { at: DELAY_TITLE, duration: 0.8, ease: 'easeOut' },
            ]);
        }

        if (meta) {
            meta.style.cssText = 'opacity:0; transform: translate3d(0,12px,0)';
            sequence.push([
                meta,
                {
                    opacity: [0, 1],
                    y: [12, 0],
                },
                { at: DELAY_META, duration: 0.8, ease: 'easeOut' },
            ]);
        }

        if (content) {
            content.style.cssText = 'opacity:0; transform: translate3d(0,12px,0)';
            sequence.push([
                content,
                {
                    opacity: [0, 1],
                    y: [12, 0],
                },
                { at: DELAY_CONTENT, duration: 0.8, ease: 'easeOut' },
            ]);
        }

        if (photo) {
            photo.style.cssText = 'opacity:0; transform: translate3d(0,10px,0)';
            sequence.push([
                photo,
                {
                    opacity: [0, 1],
                    y: [10, 0],
                },
                { at: DELAY_PHOTO, duration: 0.9, ease: 'easeOut' },
            ]);
        }

        if (sequence.length) {
            projectAnim?.stop();
            projectAnim = animate(sequence as any);
        }
    }

    window.addEventListener('load', runProjectAnimations);
    document.addEventListener('astro:page-load', runProjectAnimations);
    document.addEventListener('astro:after-swap', runProjectAnimations);
    document.addEventListener('astro:before-swap', () => {
        projectAnim?.stop();
        projectAnim = null;
    });
</script>
