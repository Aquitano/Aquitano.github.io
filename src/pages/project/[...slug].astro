---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import LinkButton from '../../components/LinkButton.astro';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    const projects = await getCollection('project');
    return projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

interface Props {
    project: CollectionEntry<'project'>;
}

const { project } = Astro.props;
const { Content } = await project.render();

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpg,jpeg,png,webp}');
const imagePath = `/src/assets/images/${project.data.fullImage}`;

let fullImageSrc: ImageMetadata | null = null;
if (project.data.fullImage) {
    if (!images[imagePath]) {
        console.warn(`Full image not found for ${imagePath}`);
    } else {
        const mod = await images[imagePath]();
        fullImageSrc = mod.default;
    }
}
---

<Layout
    title={`${project.data.title} | Breindl Thomas`}
    active="Projekte"
    SEO={{
        description: project.data.description,
        openGraph: {
            title: project.data.title,
            type: 'article',
            image: project.data.share?.image || `/images/${project.data.name}.webp`,
        },
        extend: {
            meta: {
                keywords: [...project.data.tags, ...project.data.tasks, project.data.name],
            },
        },
    }}
>
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'CreativeWork',
            name: project.data.title,
            description: project.data.description,
            creator: {
                '@type': 'Person',
                name: 'Thomas Breindl',
            },
            dateCreated: project.data.year.toString(),
            keywords: [...project.data.tags, ...project.data.tasks].join(', '),
            url: new URL(`/project/${project.slug}`, Astro.site).toString(),
        })}
    />

    <div class="scroll-container">
        <article>
            <section class="project-hero pt-24 md:pt-36 lg:pt-48 xl:pt-52" aria-labelledby="project-title">
                <div class="wrapper px-[var(--gutter)]">
                    <h1 id="project-title" class="project-title hero-animation mb-8 font-extrabold tracking-tight text-[var(--color-text-primary)]">
                        {project.data.title}
                    </h1>
                    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
                        <!-- Project Meta -->
                        <aside class="info mb-5 md:mb-0">
                            <div>
                                <div id="Desc" class="hero-animation mb-4">
                                    <p class="pre-header mb-1 text-[length:var(--text-sm)] uppercase tracking-[var(--tracking-caps)] text-[var(--color-text-tertiary)]">
                                        Aufgabe
                                    </p>
                                    <div class="mb-4 text-[length:var(--text-lg)] font-medium text-[var(--color-text-primary)]">
                                        {project.data.tasks.map((task: string) => (
                                            <span>
                                                {task}
                                                <br />
                                            </span>
                                        ))}
                                    </div>
                                    <p class="pre-header mt-6 mb-1 text-[length:var(--text-sm)] uppercase tracking-[var(--tracking-caps)] text-[var(--color-text-tertiary)]">
                                        Jahr
                                    </p>
                                    <p class="text-[length:var(--text-lg)] font-medium text-[var(--color-text-primary)]">
                                        {project.data.year}
                                    </p>
                                </div>
                            </div>
                        </aside>

                        <!-- Project Content -->
                        <div class="content col-span-2">
                            <div class="content-body prose hero-animation mb-4 text-justify font-normal text-[var(--color-text-secondary)]">
                                <Content />
                                {project.data.links && project.data.links.length > 0 && (
                                    <nav class="mt-6 flex flex-row flex-wrap gap-4" aria-label="Projektlinks">
                                        {project.data.links.map((link: { text: string; icon: string; link: string }) => (
                                            <LinkButton text={link.text} icon={link.icon} href={link.link} />
                                        ))}
                                    </nav>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            {fullImageSrc && (
                <section class="case-study-photos hero-animation pt-20" aria-label="Projektbild">
                    <div class="wrapper px-[var(--gutter)]">
                        <figure>
                            <Image
                                alt={`${project.data.title} - Vollständige Projektansicht`}
                                src={fullImageSrc}
                                height={820}
                                width={1420}
                                class="rounded-3xl"
                                loading="lazy"
                            />
                        </figure>
                    </div>
                </section>
            )}
        </article>
    </div>
</Layout>

<style>
    .scroll-container {
        padding-bottom: var(--space-section);
    }

    .wrapper {
        max-width: var(--container-6xl);
        margin: 0 auto;
    }

    .pre-header {
        padding-top: var(--space-1);
        padding-bottom: var(--space-1);
    }

    .project-hero {
        position: relative;
    }

    .project-hero::before {
        content: '';
        position: absolute;
        inset: -40px 0 0;
        pointer-events: none;
        background: radial-gradient(800px 160px at 50% 0, var(--color-border-subtle), transparent 60%);
    }

    .project-title {
        font-family: var(--font-heading);
        font-size: clamp(2.6rem, 1.2rem + 6vw, 6rem);
        line-height: var(--leading-tight);
        text-wrap: balance;
        font-weight: var(--font-black);
    }

    .content-body {
        font-size: var(--text-base);
        line-height: var(--leading-relaxed);
        text-wrap: pretty;
    }

    .case-study-photos figure {
        margin: 0;
    }

    .case-study-photos :global(img) {
        display: block;
        max-width: 100%;
        opacity: 1;
        margin: 0 auto;
        width: 100%;
    }

    .case-study-photos :global(video) {
        display: block;
        width: 100%;
    }

    .hero-animation {
        opacity: 0;
        transition: none;
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-animation {
            opacity: 1 !important;
        }
    }
</style>

<script>
    import { animate } from 'motion';

    const motionOK = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

    const DELAY_TITLE = 0.3;
    const DELAY_DESC = 0.75;
    const DELAY_BODY = 1.0;
    const DELAY_PHOTO = 1.25;

    let projectAnim: ReturnType<typeof animate> | null = null;

    function runProjectAnimations() {
        if (!motionOK) {
            // Show all elements immediately without animation
            const elements = document.querySelectorAll<HTMLElement>('.hero-animation');
            elements.forEach((el) => {
                el.style.opacity = '1';
            });
            return;
        }

        const title = document.querySelector<HTMLElement>('.project-title');
        const desc = document.querySelector<HTMLElement>('#Desc');
        const body = document.querySelector<HTMLElement>('.content-body');
        const photo = document.querySelector<HTMLElement>('.case-study-photos');

        const sequence: Parameters<typeof animate>[0] = [];

        if (title) {
            title.style.cssText = 'opacity:0; transform: translate3d(0,16px,0)';
            sequence.push([
                title,
                {
                    opacity: [0, 1],
                    y: [16, 0],
                    filter: ['blur(3px)', 'blur(0)'],
                },
                { at: DELAY_TITLE, duration: 0.9, ease: 'easeOut' },
            ]);
        }

        if (desc) {
            desc.style.cssText = 'opacity:0; transform: translate3d(0,12px,0)';
            sequence.push([
                desc,
                {
                    opacity: [0, 1],
                    y: [12, 0],
                },
                { at: DELAY_DESC, duration: 0.9, ease: 'easeOut' },
            ]);
        }

        if (body) {
            body.style.cssText = 'opacity:0; transform: translate3d(0,12px,0)';
            sequence.push([
                body,
                {
                    opacity: [0, 1],
                    y: [12, 0],
                },
                { at: DELAY_BODY, duration: 0.9, ease: 'easeOut' },
            ]);
        }

        if (photo) {
            photo.style.cssText = 'opacity:0; transform: translate3d(0,10px,0)';
            sequence.push([
                photo,
                {
                    opacity: [0, 1],
                    y: [10, 0],
                },
                { at: DELAY_PHOTO, duration: 0.9, ease: 'easeOut' },
            ]);
        }

        if (sequence.length) {
            projectAnim?.stop();
            projectAnim = animate(sequence as any);
        }
    }

    // Initialize on load and after Astro page transitions
    window.addEventListener('load', runProjectAnimations);
    document.addEventListener('astro:page-load', runProjectAnimations);
    document.addEventListener('astro:after-swap', runProjectAnimations);
    document.addEventListener('astro:before-swap', () => {
        projectAnim?.stop();
        projectAnim = null;
    });
</script>
