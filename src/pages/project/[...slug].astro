---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    const projects = await getCollection('project');
    return projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

interface Props {
    project: CollectionEntry<'project'>;
}

const { project } = Astro.props;
const { Content } = await project.render();

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpg,jpeg,png,webp}');
const imagePath = `/src/assets/images/${project.data.fullImage}`;

let fullImageSrc: ImageMetadata | null = null;
if (project.data.fullImage) {
    if (!images[imagePath]) {
        console.warn(`Full image not found for ${imagePath}`);
    } else {
        const mod = await images[imagePath]();
        fullImageSrc = mod.default;
    }
}
---

<Layout
    title={`${project.data.title} | Breindl Thomas`}
    active="Projekte"
    SEO={{
        description: project.data.description,
        openGraph: {
            title: project.data.title,
            type: 'article',
            image: project.data.share?.image || `/images/${project.data.name}.webp`,
        },
        extend: {
            meta: {
                keywords: [...project.data.tags, ...project.data.tasks, project.data.name],
            },
        },
    }}
>
    <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'CreativeWork',
            name: project.data.title,
            description: project.data.description,
            creator: {
                '@type': 'Person',
                name: 'Thomas Breindl',
            },
            dateCreated: project.data.year.toString(),
            keywords: [...project.data.tags, ...project.data.tasks].join(', '),
            url: new URL(`/project/${project.slug}`, Astro.site).toString(),
        })}
    />

    <div class="project-page pb-(--space-section)">
        <article>
            <!-- Ambient glow behind hero -->
            <div class="project-glow" aria-hidden="true"></div>

            <section class="relative pt-14 md:pt-24 lg:pt-32" aria-labelledby="project-title">
                <div class="mx-auto max-w-6xl px-(--gutter)">
                    <!-- Back link -->
                    <nav class="hero-animation mb-10 opacity-0" aria-label="Zurück">
                        <a
                            href="/#portfolio"
                            class="group/back inline-flex items-center gap-2 font-mono text-xs text-(--text-tertiary) transition-colors duration-200 hover:text-(--color-accent)"
                            data-astro-prefetch
                        >
                            <span class="transition-transform duration-200 group-hover/back:-translate-x-1">&larr;</span>
                            <span>cd ~/portfolio</span>
                        </a>
                    </nav>

                    <div class="relative mb-12 md:mb-16 lg:mb-20">
                        {
                            project.data.featured && (
                                <div class="hero-animation mb-6 flex items-center gap-3 opacity-0">
                                    <span class="font-mono text-(--color-accent)">{'['}</span>
                                    <span class="font-mono text-xs font-semibold tracking-wider text-(--color-accent) uppercase">
                                        Featured Project
                                    </span>
                                    <span class="font-mono text-(--color-accent)">{']'}</span>
                                    <div class="h-px flex-1 bg-linear-to-r from-[rgba(224,122,58,0.3)] to-transparent" />
                                </div>
                            )
                        }

                        <!-- Title with CLI decoration -->
                        <div class="hero-animation mb-8 opacity-0">
                            <div class="mb-3 font-mono text-sm text-(--text-tertiary)">
                                {'$ '}cat ./projects/{project.data.name.toLowerCase()}/README.md
                            </div>
                            <h1
                                id="project-title"
                                class="project-title font-display"
                            >
                                {project.data.title}
                            </h1>
                        </div>

                        <!-- Tags and Year -->
                        <div class="hero-animation flex flex-wrap items-center gap-2.5 pt-4 opacity-0">
                            <span class="mr-1 font-mono text-xs text-(--text-tertiary)">{'$ '}tags --list</span>
                            <span class="mr-1 font-mono text-xs text-(--text-muted)">|</span>
                            {
                                project.data.tags.map((tag: string) => (
                                    <span class="tag-chip">
                                        {tag}
                                    </span>
                                ))
                            }
                            <span class="ml-auto rounded-sm bg-(--color-accent-muted) px-3 py-1 font-mono text-xs font-semibold text-(--color-accent)">
                                {project.data.year}
                            </span>
                        </div>
                    </div>

                    <!-- Main content grid -->
                    <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1fr_380px] lg:gap-16">
                        <!-- Left column - Description -->
                        <div>
                            <section class="hero-animation mb-8 opacity-0">
                                <div class="section-heading mb-6">
                                    <span class="font-mono text-xs text-(--color-accent)">{'>'}</span>
                                    <span class="font-mono text-xs font-semibold tracking-wider text-(--text-secondary) uppercase">
                                        Overview
                                    </span>
                                    <div class="section-heading-line"></div>
                                </div>
                                <div class="prose text-base leading-relaxed text-(--text-secondary)">
                                    <Content />
                                </div>
                            </section>
                        </div>

                        <!-- Right column - Tasks & Links -->
                        <div class="order-first lg:order-last">
                            <!-- Tasks card -->
                            <section class="hero-animation mb-8 opacity-0">
                                <div class="section-heading mb-4">
                                    <span class="font-mono text-xs text-(--color-accent)">{'>'}</span>
                                    <span class="font-mono text-xs font-semibold tracking-wider text-(--text-secondary) uppercase">
                                        Key Contributions
                                    </span>
                                    <div class="section-heading-line"></div>
                                </div>
                                <div class="tasks-card">
                                    <div class="tasks-card-header">
                                        <span>{'$ '}cat tasks.log</span>
                                        <span class="tasks-card-dots" aria-hidden="true">
                                            <span></span><span></span><span></span>
                                        </span>
                                    </div>
                                    <ul class="flex flex-col gap-3">
                                        {
                                            project.data.tasks.map((task: string, index: number) => (
                                                <li class="task-item">
                                                    <span class="task-index">
                                                        {String(index + 1).padStart(2, '0')}
                                                    </span>
                                                    <span class="task-arrow" aria-hidden="true">-></span>
                                                    <span class="task-text">
                                                        {task}
                                                    </span>
                                                </li>
                                            ))
                                        }
                                    </ul>
                                    <div class="tasks-card-footer">
                                        <span>exit code: 0</span>
                                        <span>{project.data.tasks.length} tasks completed</span>
                                    </div>
                                </div>
                            </section>

                            <!-- Links section -->
                            {
                                project.data.links && project.data.links.length > 0 && (
                                    <section class="hero-animation mb-8 opacity-0">
                                        <div class="section-heading mb-4">
                                            <span class="font-mono text-xs text-(--color-accent)">{'>'}</span>
                                            <span class="font-mono text-xs font-semibold tracking-wider text-(--text-secondary) uppercase">
                                                Links
                                            </span>
                                            <div class="section-heading-line" />
                                        </div>
                                        <div class="flex flex-col gap-2.5">
                                            {project.data.links.map(
                                                (link: { text: string; icon: string; link: string }, index: number) => (
                                                    <a
                                                        href={link.link}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        class="link-card group/link"
                                                    >
                                                        <span class="link-card-index">
                                                            {String(index + 1).padStart(2, '0')}
                                                        </span>
                                                        <span class="link-card-text">
                                                            {link.text}
                                                        </span>
                                                        <span class="link-card-arrow">
                                                            ->
                                                        </span>
                                                    </a>
                                                ),
                                            )}
                                        </div>
                                        <div class="mt-3 font-mono text-xs text-white/25">{'$ '}open --external</div>
                                    </section>
                                )
                            }
                        </div>
                    </div>
                </div>
            </section>

            {
                fullImageSrc && (
                    <section class="hero-animation mt-16 opacity-0 md:mt-20" aria-label="Projektbild">
                        <div class="mx-auto max-w-6xl px-(--gutter)">
                            <div class="image-frame">
                                <figure class="m-0">
                                    <Image
                                        alt={`${project.data.title} - Vollständige Projektansicht`}
                                        src={fullImageSrc}
                                        height={820}
                                        width={1420}
                                        class="block h-auto w-full rounded-xl"
                                        loading="lazy"
                                    />
                                </figure>
                            </div>
                        </div>
                    </section>
                )
            }
        </article>
    </div>
</Layout>

<style>
    /* Page container */
    .project-page {
        position: relative;
        overflow: hidden;
    }

    /* Ambient glow behind hero area */
    .project-glow {
        position: absolute;
        top: -120px;
        left: 50%;
        transform: translateX(-50%);
        width: 800px;
        height: 400px;
        background: radial-gradient(ellipse at center, rgba(224, 122, 58, 0.08) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
    }

    /* Project title */
    .project-title {
        font-size: var(--text-5xl);
        font-weight: var(--font-black);
        line-height: var(--leading-none);
        letter-spacing: var(--tracking-tight);
        color: var(--text-primary);
    }

    /* Tag chips in the tags row */
    .tag-chip {
        display: inline-flex;
        align-items: center;
        padding: var(--space-1) var(--space-3);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: var(--font-medium);
        color: var(--text-secondary);
        background: transparent;
        border: 1px solid var(--border-default);
        border-radius: var(--radius-sm);
        letter-spacing: var(--tracking-wider);
        transition:
            border-color var(--duration-fast) var(--ease-out),
            color var(--duration-fast) var(--ease-out);
    }

    .tag-chip:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
    }

    /* Section heading row (> LABEL ---) */
    .section-heading {
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }

    .section-heading-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, rgba(0, 0, 0, 0.1), transparent);
    }

    /* Tasks card (terminal-style) */
    .tasks-card {
        background: var(--bg-card);
        border: 1px solid var(--bg-card-border);
        border-radius: var(--radius-lg);
        padding: var(--space-5);
        overflow: hidden;
        transition: border-color var(--duration-fast) var(--ease-out);
    }

    .tasks-card:hover {
        border-color: var(--bg-card-border-hover);
    }

    .tasks-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: var(--space-4);
        padding-bottom: var(--space-3);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.35);
    }

    .tasks-card-dots {
        display: flex;
        gap: 5px;
    }

    .tasks-card-dots span {
        width: 8px;
        height: 8px;
        border-radius: var(--radius-full);
        background: rgba(255, 255, 255, 0.15);
    }

    .tasks-card-dots span:first-child {
        background: rgba(255, 99, 71, 0.6);
    }

    .tasks-card-dots span:nth-child(2) {
        background: rgba(255, 193, 7, 0.6);
    }

    .tasks-card-dots span:last-child {
        background: rgba(76, 175, 80, 0.6);
    }

    .tasks-card-footer {
        display: flex;
        justify-content: space-between;
        margin-top: var(--space-4);
        padding-top: var(--space-3);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.25);
    }

    /* Individual task item */
    .task-item {
        display: flex;
        align-items: flex-start;
        gap: var(--space-3);
        transition: opacity var(--duration-fast) var(--ease-out);
    }

    .task-index {
        flex-shrink: 0;
        margin-top: 1px;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(224, 122, 58, 0.7);
        font-variant-numeric: tabular-nums;
    }

    .task-arrow {
        flex-shrink: 0;
        margin-top: 1px;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.4);
    }

    .task-text {
        flex: 1;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        line-height: var(--leading-relaxed);
        color: rgba(255, 255, 255, 0.8);
        transition: color var(--duration-fast) var(--ease-out);
    }

    .task-item:hover .task-text {
        color: rgba(255, 255, 255, 1);
    }

    /* Link cards */
    .link-card {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        padding: var(--space-3) var(--space-4);
        background: var(--bg-card);
        border: 1px solid var(--bg-card-border);
        border-radius: var(--radius-md);
        text-decoration: none;
        transition:
            border-color var(--duration-fast) var(--ease-out),
            background var(--duration-fast) var(--ease-out);
    }

    .link-card:hover {
        border-color: rgba(224, 122, 58, 0.5);
        background: rgba(75, 75, 75, 0.9);
    }

    .link-card-index {
        flex-shrink: 0;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.4);
        font-variant-numeric: tabular-nums;
    }

    .link-card-text {
        flex: 1;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: rgba(255, 255, 255, 0.8);
        transition: color var(--duration-fast) var(--ease-out);
    }

    .link-card:hover .link-card-text {
        color: rgba(255, 255, 255, 1);
    }

    .link-card-arrow {
        flex-shrink: 0;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.4);
        transition:
            color var(--duration-fast) var(--ease-out),
            transform var(--duration-fast) var(--ease-out);
    }

    .link-card:hover .link-card-arrow {
        color: var(--color-accent);
        transform: translateX(3px);
    }

    /* Image frame around project screenshot */
    .image-frame {
        border: 1px solid var(--border-default);
        border-radius: var(--radius-xl);
        padding: var(--space-2);
        background: var(--bg-elevated);
        box-shadow: var(--shadow-elevated);
    }

    /* Prose styling for content */
    .prose :global(p) {
        margin-bottom: var(--space-5);
    }

    .prose :global(strong) {
        font-weight: var(--font-semibold);
        color: var(--text-primary);
    }

    /* Animations */
    .hero-animation {
        opacity: 0;
        transition: none;
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-animation {
            opacity: 1 !important;
        }

        .tag-chip,
        .tasks-card,
        .link-card,
        .link-card-arrow,
        .link-card-text,
        .task-text {
            transition: none;
        }
    }
</style>

<script>
    import { animate, type AnimationSequence } from 'motion';

    const motionOK = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

    let projectAnim: ReturnType<typeof animate> | null = null;

    function runProjectAnimations() {
        if (!motionOK) {
            const elements = document.querySelectorAll<HTMLElement>('.hero-animation');
            elements.forEach((el) => {
                el.style.opacity = '1';
            });
            return;
        }

        const animatedElements = document.querySelectorAll<HTMLElement>('.hero-animation');
        const sequence: AnimationSequence = [];

        animatedElements.forEach((el, index) => {
            const delay = 0.2 + index * 0.1;
            el.style.cssText = 'opacity:0; transform: translate3d(0,12px,0)';
            sequence.push([
                el,
                {
                    opacity: [0, 1],
                    y: [12, 0],
                },
                { at: delay, duration: 0.7, ease: 'easeOut' },
            ]);
        });

        if (sequence.length) {
            projectAnim?.stop();
            projectAnim = animate(sequence as any);
        }
    }

    window.addEventListener('load', runProjectAnimations);
    document.addEventListener('astro:page-load', runProjectAnimations);
    document.addEventListener('astro:after-swap', runProjectAnimations);
    document.addEventListener('astro:before-swap', () => {
        projectAnim?.stop();
        projectAnim = null;
    });
</script>
