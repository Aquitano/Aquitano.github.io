---
import Layout from '../layouts/Layout.astro';
import { defaultLang, languages, type Lang, ui } from '../i18n/ui';
import { getLocalePath } from '../i18n/utils';

// 404 is always served from root; detect language from URL path
const pathLang = Astro.url.pathname.split('/').filter(Boolean)[0];
const lang: Lang =
    pathLang && Object.hasOwn(languages, pathLang) ? (pathLang as Lang) : defaultLang;
const t = (key: keyof (typeof ui)[typeof defaultLang]) => ui[lang][key];
---

<Layout
    title={t('seo.404Title')}
    active="home"
    lang={lang}
    SEO={{
        description: t('seo.404Desc'),
        openGraph: {
            title: t('seo.404Title'),
            type: 'website',
        },
    }}
>
    <div class="error-page">
        <div class="error-content">
            <span class="error-tag">// Error</span>
            <h1 class="error-code">404</h1>
            <h2 class="error-title">{t('error.title')}</h2>
            <p class="error-message">{t('error.message')}</p>
            <a href={getLocalePath(lang, '/')} class="btn btn-primary">
                <span class="btn-arrow" aria-hidden="true">&larr;</span>
                {t('error.back')}
            </a>
        </div>
        <div class="ascii-deco ascii-deco-left" aria-hidden="true">&gt;&gt;&gt;</div>
        <div class="ascii-deco ascii-deco-right" aria-hidden="true">###</div>
    </div>
</Layout>

<style>
    @reference "../styles/global.css";

    .error-page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        min-height: 100dvh;
        padding: var(--gutter);
        position: relative;
    }

    .error-content {
        text-align: center;
        max-width: 480px;
    }

    .error-tag {
        display: block;
        @apply font-mono text-sm tracking-wide;
        color: var(--color-accent);
        margin-bottom: 1rem;
    }

    .error-code {
        @apply font-display tracking-tight;
        font-size: clamp(6rem, 20vw, 12rem);
        font-weight: 900;
        line-height: 1;
        @apply text-primary;
        margin-bottom: 1rem;
    }

    .error-title {
        @apply font-heading;
        @apply text-2xl;
        font-weight: 700;
        @apply text-primary;
        margin-bottom: 1rem;
    }

    .error-message {
        @apply text-lg leading-relaxed;
        @apply text-secondary;
        margin-bottom: 2rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-arrow {
        @apply font-mono;
        transition: transform var(--duration-fast) var(--ease-out);
    }

    .btn:hover .btn-arrow {
        transform: translateX(-4px);
    }

    .ascii-deco {
        position: absolute;
        @apply font-mono;
        @apply text-sm tracking-widest;
        @apply text-muted;
        opacity: 0.4;
        pointer-events: none;
        user-select: none;
    }

    .ascii-deco-left {
        bottom: 2rem;
        left: var(--gutter);
    }

    .ascii-deco-right {
        bottom: 2rem;
        right: var(--gutter);
    }

    @media (max-width: 640px) {
        .ascii-deco {
            display: none;
        }
    }
</style>
