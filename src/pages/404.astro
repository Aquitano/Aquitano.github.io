---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="404 - Seite nicht gefunden | Thomas Breindl"
    active="Home"
    SEO={{
        description:
            "Die angeforderte Seite wurde nicht gefunden. Zurück zur Startseite von Thomas Breindl's Portfolio.",
        openGraph: {
            title: '404 - Seite nicht gefunden',
            type: 'website',
        },
    }}
>
    <div class="error-page">
        <div class="error-content">
            <span class="error-tag">// Error</span>
            <h1 class="error-code">404</h1>
            <h2 class="error-title">Seite nicht gefunden</h2>
            <p class="error-message">
                Die angeforderte Seite existiert nicht oder wurde verschoben.
            </p>
            <a href="/" class="btn btn-primary">
                <span class="btn-arrow" aria-hidden="true">&larr;</span>
                Zurück zur Startseite
            </a>
        </div>
        <div class="ascii-deco ascii-deco-left" aria-hidden="true">&gt;&gt;&gt;</div>
        <div class="ascii-deco ascii-deco-right" aria-hidden="true">###</div>
    </div>
</Layout>

<style>
    .error-page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        min-height: 100dvh;
        padding: var(--gutter);
        position: relative;
    }

    .error-content {
        text-align: center;
        max-width: 480px;
    }

    .error-tag {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--color-accent);
        letter-spacing: var(--tracking-wide);
        margin-bottom: var(--space-4);
    }

    .error-code {
        font-family: var(--font-display);
        font-size: clamp(6rem, 20vw, 12rem);
        font-weight: var(--font-black);
        line-height: var(--leading-none);
        color: var(--text-primary);
        letter-spacing: var(--tracking-tight);
        margin-bottom: var(--space-4);
    }

    .error-title {
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
        font-weight: var(--font-bold);
        color: var(--text-primary);
        margin-bottom: var(--space-4);
    }

    .error-message {
        font-size: var(--text-lg);
        color: var(--text-secondary);
        margin-bottom: var(--space-8);
        line-height: var(--leading-relaxed);
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
    }

    .btn-arrow {
        font-family: var(--font-mono);
        transition: transform var(--duration-fast) var(--ease-out);
    }

    .btn:hover .btn-arrow {
        transform: translateX(-4px);
    }

    .ascii-deco {
        position: absolute;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--text-muted);
        letter-spacing: 0.1em;
        opacity: 0.4;
        pointer-events: none;
        user-select: none;
    }

    .ascii-deco-left {
        bottom: var(--space-8);
        left: var(--gutter);
    }

    .ascii-deco-right {
        bottom: var(--space-8);
        right: var(--gutter);
    }

    @media (max-width: 640px) {
        .ascii-deco {
            display: none;
        }
    }
</style>
