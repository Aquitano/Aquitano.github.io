---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="Kontakt | Breindl Thomas"
    active="Kontakt"
    SEO={{
        description:
            'Kontaktieren Sie Thomas Breindl für Webentwicklung, Design und Programmierungsprojekte. Portfolio-Anfragen willkommen.',
        openGraph: {
            title: 'Kontakt - Thomas Breindl',
            type: 'website',
        },
    }}
>
    <section class="relative flex min-h-screen items-center justify-center px-[var(--gutter)] py-16 sm:py-24">
        <div class="mx-auto w-full max-w-6xl">
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-12">
                <!-- Contact Info -->
                <div class="rounded-2xl bg-[var(--color-bg-secondary)] p-8 lg:p-10">
                    <h1
                        class="text-[length:var(--text-4xl)] font-extrabold leading-[var(--leading-tight)] tracking-[var(--tracking-tight)] text-[var(--color-text-primary)]"
                    >
                        Kontaktieren Sie mich
                    </h1>
                    <p class="mt-4 text-[length:var(--text-lg)] text-[var(--color-text-secondary)]">
                        Füllen Sie das Formular aus, um ein Gespräch zu beginnen
                    </p>

                    <address class="mt-10 space-y-6 not-italic">
                        <!-- Location -->
                        <div class="flex items-start gap-4 text-[var(--color-text-secondary)]">
                            <div
                                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[var(--color-accent-muted)]"
                                aria-hidden="true"
                            >
                                <svg
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    viewBox="0 0 24 24"
                                    class="h-5 w-5 text-[var(--color-accent)]"
                                >
                                    <path
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                    ></path>
                                    <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="text-[length:var(--text-sm)] font-medium text-[var(--color-text-tertiary)]">
                                    Standort
                                </p>
                                <p class="text-[length:var(--text-base)] font-semibold text-[var(--color-text-primary)]">
                                    Passau, Deutschland
                                </p>
                            </div>
                        </div>

                        <!-- Twitter / X -->
                        <div class="flex items-start gap-4 text-[var(--color-text-secondary)]">
                            <div
                                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[var(--color-accent-muted)]"
                                aria-hidden="true"
                            >
                                <Icon name="mdi:twitter" class="h-5 w-5 text-[var(--color-accent)]" />
                            </div>
                            <div>
                                <p class="text-[length:var(--text-sm)] font-medium text-[var(--color-text-tertiary)]">
                                    Twitter / X
                                </p>
                                <a
                                    href="https://twitter.com/BreindlThomas"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-[length:var(--text-base)] font-semibold text-[var(--color-text-primary)] underline decoration-[var(--color-border-default)] underline-offset-2 transition-colors hover:text-[var(--color-accent)] hover:decoration-[var(--color-accent)]"
                                >
                                    @BreindlThomas
                                </a>
                            </div>
                        </div>

                        <!-- GitHub -->
                        <div class="flex items-start gap-4 text-[var(--color-text-secondary)]">
                            <div
                                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[var(--color-accent-muted)]"
                                aria-hidden="true"
                            >
                                <Icon name="mdi:github" class="h-5 w-5 text-[var(--color-accent)]" />
                            </div>
                            <div>
                                <p class="text-[length:var(--text-sm)] font-medium text-[var(--color-text-tertiary)]">
                                    GitHub
                                </p>
                                <a
                                    href="https://github.com/Aquitano"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-[length:var(--text-base)] font-semibold text-[var(--color-text-primary)] underline decoration-[var(--color-border-default)] underline-offset-2 transition-colors hover:text-[var(--color-accent)] hover:decoration-[var(--color-accent)]"
                                >
                                    Aquitano
                                </a>
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="flex items-start gap-4 text-[var(--color-text-secondary)]">
                            <div
                                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[var(--color-accent-muted)]"
                                aria-hidden="true"
                            >
                                <svg
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    viewBox="0 0 24 24"
                                    class="h-5 w-5 text-[var(--color-accent)]"
                                >
                                    <path
                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <p class="text-[length:var(--text-sm)] font-medium text-[var(--color-text-tertiary)]">
                                    E-Mail
                                </p>
                                <a
                                    href="mailto:ThomasBreindl@proton.me"
                                    class="text-[length:var(--text-base)] font-semibold text-[var(--color-text-primary)] underline decoration-[var(--color-border-default)] underline-offset-2 transition-colors hover:text-[var(--color-accent)] hover:decoration-[var(--color-accent)]"
                                >
                                    ThomasBreindl@proton.me
                                </a>
                            </div>
                        </div>
                    </address>
                </div>

                <!-- Contact Form -->
                <form
                    class="flex flex-col justify-center space-y-6 rounded-2xl bg-[var(--color-bg-secondary)] p-8 lg:p-10"
                    name="contact"
                    data-netlify-recaptcha="true"
                    data-netlify="true"
                    method="POST"
                    novalidate
                    aria-label="Kontaktformular"
                >
                    <input type="hidden" name="form-name" value="contact" />

                    <!-- Name Field -->
                    <div class="flex flex-col gap-2">
                        <label for="name" class="label">
                            Vollständiger Name
                            <span class="text-[var(--color-error)]" aria-hidden="true">*</span>
                        </label>
                        <input
                            type="text"
                            name="name"
                            id="name"
                            autocomplete="name"
                            required
                            aria-required="true"
                            class="input"
                            placeholder="Max Mustermann"
                        />
                    </div>

                    <!-- Email Field -->
                    <div class="flex flex-col gap-2">
                        <label for="email" class="label">
                            E-Mail
                            <span class="text-[var(--color-error)]" aria-hidden="true">*</span>
                        </label>
                        <input
                            type="email"
                            name="email"
                            id="email"
                            autocomplete="email"
                            required
                            aria-required="true"
                            aria-describedby="email-hint"
                            class="input"
                            placeholder="max@beispiel.de"
                        />
                        <p id="email-hint" class="text-[length:var(--text-xs)] text-[var(--color-text-tertiary)]">
                            Ihre E-Mail wird nur für die Kontaktaufnahme verwendet.
                        </p>
                    </div>

                    <!-- Phone Field -->
                    <div class="flex flex-col gap-2">
                        <label for="tel" class="label">
                            Telefonnummer
                            <span class="text-[var(--color-error)]" aria-hidden="true">*</span>
                        </label>
                        <input
                            type="tel"
                            name="tel"
                            id="tel"
                            autocomplete="tel"
                            required
                            aria-required="true"
                            class="input"
                            placeholder="+49 123 456789"
                        />
                    </div>

                    <!-- Message Field -->
                    <div class="flex flex-col gap-2">
                        <label for="message" class="label">
                            Nachricht
                            <span class="text-[var(--color-error)]" aria-hidden="true">*</span>
                        </label>
                        <textarea
                            name="message"
                            id="message"
                            required
                            aria-required="true"
                            rows="5"
                            class="input min-h-32 resize-y"
                            placeholder="Ihre Nachricht..."
                        ></textarea>
                    </div>

                    <!-- reCAPTCHA -->
                    <div data-netlify-recaptcha="true"></div>

                    <!-- Error message container (populated by JS) -->
                    <div
                        id="form-error"
                        role="alert"
                        aria-live="polite"
                        class="hidden rounded-lg bg-[color-mix(in_srgb,var(--color-error)_15%,transparent)] p-4 text-[length:var(--text-sm)] text-[var(--color-error)]"
                    >
                    </div>

                    <!-- Success message container (populated by JS) -->
                    <div
                        id="form-success"
                        role="status"
                        aria-live="polite"
                        class="hidden rounded-lg bg-[color-mix(in_srgb,var(--color-success)_15%,transparent)] p-4 text-[length:var(--text-sm)] text-[var(--color-success)]"
                    >
                    </div>

                    <button
                        type="submit"
                        class="btn btn-primary mt-2 w-full py-3 text-[length:var(--text-base)] font-bold sm:w-auto sm:px-8"
                    >
                        Absenden
                    </button>
                </form>
            </div>
        </div>
    </section>
</Layout>

<script>
    function initContactForm() {
        const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
        const errorContainer = document.getElementById('form-error');
        const successContainer = document.getElementById('form-success');

        if (!form || !errorContainer || !successContainer) return;

        function showError(message: string) {
            if (!errorContainer || !successContainer) return;
            errorContainer.textContent = message;
            errorContainer.classList.remove('hidden');
            successContainer.classList.add('hidden');
        }

        function showSuccess(message: string) {
            if (!errorContainer || !successContainer) return;
            successContainer.textContent = message;
            successContainer.classList.remove('hidden');
            errorContainer.classList.add('hidden');
        }

        function hideMessages() {
            if (!errorContainer || !successContainer) return;
            errorContainer.classList.add('hidden');
            successContainer.classList.add('hidden');
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideMessages();

            const nameInput = form.querySelector<HTMLInputElement>('#name');
            const emailInput = form.querySelector<HTMLInputElement>('#email');
            const telInput = form.querySelector<HTMLInputElement>('#tel');
            const messageInput = form.querySelector<HTMLTextAreaElement>('#message');

            const name = nameInput?.value.trim() ?? '';
            const email = emailInput?.value.trim() ?? '';
            const tel = telInput?.value.replace(/\s/g, '') ?? '';
            const message = messageInput?.value.trim() ?? '';

            // Validation
            if (!name || !email || !tel || !message) {
                showError('Bitte füllen Sie alle Pflichtfelder aus.');
                return;
            }

            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                showError('Bitte geben Sie eine gültige E-Mail-Adresse an.');
                emailInput?.focus();
                return;
            }

            if (!/^[0-9\-+]{9,15}$/.test(tel)) {
                showError('Bitte geben Sie eine gültige Telefonnummer an (9-15 Ziffern).');
                telInput?.focus();
                return;
            }

            const formData = new URLSearchParams({
                'form-name': 'contact',
                name,
                email,
                tel,
                message,
            });

            try {
                const response = await fetch('/', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: formData.toString(),
                });

                if (response.ok) {
                    showSuccess('Vielen Dank! Ihre Nachricht wurde erfolgreich gesendet.');
                    form.reset();
                } else {
                    showError('Beim Senden ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut.');
                }
            } catch {
                showError('Netzwerkfehler. Bitte überprüfen Sie Ihre Internetverbindung.');
            }
        });
    }

    // Initialize on load and after Astro page transitions
    document.addEventListener('DOMContentLoaded', initContactForm);
    document.addEventListener('astro:after-swap', initContactForm);
    initContactForm();
</script>
