---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="Kontakt | Breindl Thomas"
    active="Kontakt"
    SEO={{
        description:
            'Kontaktieren Sie Thomas Breindl für Webentwicklung, Design und Programmierungsprojekte. Portfolio-Anfragen willkommen.',
        openGraph: {
            title: 'Kontakt - Thomas Breindl',
            type: 'website',
        },
    }}
>
    <section class="contact-page">
        <div class="mx-auto w-full max-w-6xl">
            <div class="contact-header">
                <span class="section-tag">// Contact</span>
                <h1>Kontaktieren Sie mich</h1>
                <p class="contact-subtitle">Füllen Sie das Formular aus, um ein Gespräch zu beginnen</p>
            </div>
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-12">
                <!-- Contact Info -->
                <div class="contact-card">
                    <div class="card-ascii" aria-hidden="true">$$$$$</div>
                    <h2 class="card-title">Kontaktdaten</h2>

                    <address class="contact-list not-italic">
                        <!-- Location -->
                        <div class="contact-item">
                            <div class="contact-icon" aria-hidden="true">
                                <svg
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    viewBox="0 0 24 24"
                                    class="h-5 w-5"
                                >
                                    <path
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                    ></path>
                                    <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="contact-label">Standort</p>
                                <p class="contact-value">Passau, Deutschland</p>
                            </div>
                        </div>

                        <!-- Twitter / X -->
                        <div class="contact-item">
                            <div class="contact-icon" aria-hidden="true">
                                <Icon name="mdi:twitter" class="h-5 w-5" />
                            </div>
                            <div>
                                <p class="contact-label">Twitter / X</p>
                                <a
                                    href="https://twitter.com/BreindlThomas"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="contact-link"
                                >
                                    @BreindlThomas
                                </a>
                            </div>
                        </div>

                        <!-- GitHub -->
                        <div class="contact-item">
                            <div class="contact-icon" aria-hidden="true">
                                <Icon name="mdi:github" class="h-5 w-5" />
                            </div>
                            <div>
                                <p class="contact-label">GitHub</p>
                                <a
                                    href="https://github.com/Aquitano"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="contact-link"
                                >
                                    Aquitano
                                </a>
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="contact-item">
                            <div class="contact-icon" aria-hidden="true">
                                <svg
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    viewBox="0 0 24 24"
                                    class="h-5 w-5"
                                >
                                    <path
                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <p class="contact-label">E-Mail</p>
                                <a href="mailto:ThomasBreindl@proton.me" class="contact-link">
                                    ThomasBreindl@proton.me
                                </a>
                            </div>
                        </div>
                    </address>
                </div>

                <!-- Contact Form -->
                <form
                    class="contact-card"
                    name="contact"
                    data-netlify-recaptcha="true"
                    data-netlify="true"
                    method="POST"
                    novalidate
                    aria-label="Kontaktformular"
                >
                    <div class="card-ascii" aria-hidden="true">////</div>
                    <input type="hidden" name="form-name" value="contact" />

                    <!-- Name Field -->
                    <div class="form-field">
                        <label for="name" class="form-label">
                            Vollständiger Name
                            <span class="required" aria-hidden="true">*</span>
                        </label>
                        <input
                            type="text"
                            name="name"
                            id="name"
                            autocomplete="name"
                            required
                            aria-required="true"
                            class="form-input"
                            placeholder="Max Mustermann"
                        />
                    </div>

                    <!-- Email Field -->
                    <div class="form-field">
                        <label for="email" class="form-label">
                            E-Mail
                            <span class="required" aria-hidden="true">*</span>
                        </label>
                        <input
                            type="email"
                            name="email"
                            id="email"
                            autocomplete="email"
                            required
                            aria-required="true"
                            aria-describedby="email-hint"
                            class="form-input"
                            placeholder="max@beispiel.de"
                        />
                        <p id="email-hint" class="form-hint">Ihre E-Mail wird nur für die Kontaktaufnahme verwendet.</p>
                    </div>

                    <!-- Phone Field -->
                    <div class="form-field">
                        <label for="tel" class="form-label">
                            Telefonnummer
                            <span class="required" aria-hidden="true">*</span>
                        </label>
                        <input
                            type="tel"
                            name="tel"
                            id="tel"
                            autocomplete="tel"
                            required
                            aria-required="true"
                            class="form-input"
                            placeholder="+49 123 456789"
                        />
                    </div>

                    <!-- Message Field -->
                    <div class="form-field">
                        <label for="message" class="form-label">
                            Nachricht
                            <span class="required" aria-hidden="true">*</span>
                        </label>
                        <textarea
                            name="message"
                            id="message"
                            required
                            aria-required="true"
                            rows="5"
                            class="form-input form-textarea"
                            placeholder="Ihre Nachricht..."></textarea>
                    </div>

                    <!-- reCAPTCHA -->
                    <div data-netlify-recaptcha="true"></div>

                    <!-- Error message container -->
                    <div id="form-error" role="alert" aria-live="polite" class="form-message form-error hidden"></div>

                    <!-- Success message container -->
                    <div id="form-success" role="status" aria-live="polite" class="form-message form-success hidden">
                    </div>

                    <button type="submit" class="btn btn-primary submit-btn">
                        Absenden
                        <span class="btn-arrow" aria-hidden="true">&rarr;</span>
                    </button>
                </form>
            </div>
        </div>
    </section>
</Layout>

<script>
    function initContactForm() {
        const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
        const errorContainer = document.getElementById('form-error');
        const successContainer = document.getElementById('form-success');

        if (!form || !errorContainer || !successContainer) return;
        if (form.dataset.contactInitialized === 'true') return;

        function showError(message: string) {
            if (!errorContainer || !successContainer) return;
            errorContainer.textContent = message;
            errorContainer.classList.remove('hidden');
            successContainer.classList.add('hidden');
        }

        function showSuccess(message: string) {
            if (!errorContainer || !successContainer) return;
            successContainer.textContent = message;
            successContainer.classList.remove('hidden');
            errorContainer.classList.add('hidden');
        }

        function hideMessages() {
            if (!errorContainer || !successContainer) return;
            errorContainer.classList.add('hidden');
            successContainer.classList.add('hidden');
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideMessages();

            const nameInput = form.querySelector<HTMLInputElement>('#name');
            const emailInput = form.querySelector<HTMLInputElement>('#email');
            const telInput = form.querySelector<HTMLInputElement>('#tel');
            const messageInput = form.querySelector<HTMLTextAreaElement>('#message');

            const name = nameInput?.value.trim() ?? '';
            const email = emailInput?.value.trim() ?? '';
            const tel = telInput?.value.replace(/\s/g, '') ?? '';
            const message = messageInput?.value.trim() ?? '';

            // Validation
            if (!name || !email || !tel || !message) {
                showError('Bitte füllen Sie alle Pflichtfelder aus.');
                return;
            }

            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                showError('Bitte geben Sie eine gültige E-Mail-Adresse an.');
                emailInput?.focus();
                return;
            }

            if (!/^[0-9\-+]{9,15}$/.test(tel)) {
                showError('Bitte geben Sie eine gültige Telefonnummer an (9-15 Ziffern).');
                telInput?.focus();
                return;
            }

            const formData = new FormData(form);
            formData.set('name', name);
            formData.set('email', email);
            formData.set('tel', tel);
            formData.set('message', message);

            const body = new URLSearchParams();
            formData.forEach((value, key) => {
                body.append(key, typeof value === 'string' ? value : value.name);
            });

            try {
                const response = await fetch('/', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body.toString(),
                });

                if (response.ok) {
                    showSuccess('Vielen Dank! Ihre Nachricht wurde erfolgreich gesendet.');
                    form.reset();
                } else {
                    showError('Beim Senden ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut.');
                }
            } catch {
                showError('Netzwerkfehler. Bitte überprüfen Sie Ihre Internetverbindung.');
            }
        });

        form.dataset.contactInitialized = 'true';
    }

    // Initialize on load and after Astro page transitions
    document.addEventListener('DOMContentLoaded', initContactForm);
    document.addEventListener('astro:after-swap', initContactForm);
    initContactForm();
</script>

<style>
    .contact-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: var(--space-section) var(--gutter);
    }

    .contact-header {
        text-align: center;
        margin-bottom: var(--space-component);
    }

    .section-tag {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--color-accent);
        letter-spacing: var(--tracking-wide);
        margin-bottom: var(--space-4);
    }

    .contact-header h1 {
        font-family: var(--font-display);
        font-size: var(--text-5xl);
        font-weight: var(--font-black);
        color: var(--text-primary);
        letter-spacing: var(--tracking-tight);
        margin-bottom: var(--space-4);
    }

    .contact-subtitle {
        font-size: var(--text-lg);
        color: var(--text-secondary);
    }

    .contact-card {
        background: var(--bg-card);
        border: 1px solid var(--bg-card-border);
        border-radius: var(--radius-xl);
        padding: var(--space-8);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .card-ascii {
        position: absolute;
        top: var(--space-3);
        right: var(--space-4);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.15);
        letter-spacing: 0.05em;
        pointer-events: none;
        user-select: none;
    }

    .card-title {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: var(--font-medium);
        color: var(--color-accent);
        text-transform: uppercase;
        letter-spacing: var(--tracking-caps);
    }

    .contact-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .contact-item {
        display: flex;
        align-items: flex-start;
        gap: var(--space-4);
    }

    .contact-icon {
        flex-shrink: 0;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(224, 122, 58, 0.15);
        border-radius: var(--radius-md);
        color: var(--color-accent);
    }

    .contact-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.6);
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
        margin-bottom: var(--space-1);
    }

    .contact-value {
        font-size: var(--text-base);
        font-weight: var(--font-semibold);
        color: var(--text-inverse);
    }

    .contact-link {
        font-size: var(--text-base);
        font-weight: var(--font-semibold);
        color: var(--text-inverse);
        text-decoration: underline;
        text-decoration-color: rgba(255, 255, 255, 0.3);
        text-underline-offset: 2px;
        transition:
            color var(--duration-fast) var(--ease-out),
            text-decoration-color var(--duration-fast) var(--ease-out);
    }

    .contact-link:hover {
        color: var(--color-accent);
        text-decoration-color: var(--color-accent);
    }

    .form-field {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .form-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: var(--font-medium);
        color: rgba(255, 255, 255, 0.7);
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
    }

    .required {
        color: var(--color-accent);
    }

    .form-input {
        width: 100%;
        padding: var(--space-3) var(--space-4);
        font-size: var(--text-base);
        font-weight: var(--font-medium);
        color: var(--text-inverse);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: var(--radius-md);
        transition: border-color var(--duration-fast) var(--ease-out);
    }

    .form-input::placeholder {
        color: rgba(255, 255, 255, 0.4);
    }

    .form-input:hover {
        border-color: rgba(255, 255, 255, 0.25);
    }

    .form-input:focus {
        border-color: var(--color-accent);
        outline: none;
    }

    .form-textarea {
        min-height: 120px;
        resize: vertical;
    }

    .form-hint {
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.5);
    }

    .form-message {
        padding: var(--space-4);
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
    }

    .form-error {
        background: rgba(255, 89, 89, 0.15);
        color: #ff5959;
    }

    .form-success {
        background: rgba(89, 255, 89, 0.15);
        color: #59ff59;
    }

    .submit-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        align-self: flex-start;
        padding: var(--space-3) var(--space-6);
    }

    .btn-arrow {
        font-family: var(--font-mono);
        transition: transform var(--duration-fast) var(--ease-out);
    }

    .submit-btn:hover .btn-arrow {
        transform: translateX(4px);
    }

    .hidden {
        display: none;
    }
</style>
