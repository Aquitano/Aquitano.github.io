---
import { SEO } from 'astro-seo';
import '@fontsource-variable/archivo/standard.css';
import '@fontsource-variable/geist-mono';
import '../styles/global.css';
import { site, socials } from '../lib/data';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const defaultKeywords = [
    'Thomas Breindl',
    'Thomas',
    'Breindl',
    'Portfolio',
    'Aquitano',
    'Software Developer',
    'Software Engineer',
    'Designer',
    'Passau',
    'Germany',
];

export interface Props {
    title?: string;
    description?: string;
    ogTitle?: string;
}

const {
    title = `${site.name} | ${site.role}`,
    description = 'Software developer, designer and CS student in Passau, Germany. Building robust backend systems, event pipelines and interfaces people enjoy using.',
    ogTitle,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#0a0a0b" />
        <meta name="color-scheme" content="dark" />

        <SEO
            title={title}
            description={description}
            canonical={canonicalURL.toString()}
            openGraph={{
                basic: {
                    title: ogTitle || title,
                    type: 'website',
                    image: new URL('/og-default.png', Astro.site).toString(),
                    url: canonicalURL.toString(),
                },
                optional: {
                    locale: 'en_US',
                    siteName: site.name,
                    description,
                },
            }}
            twitter={{
                creator: '@breindlthomas',
                card: 'summary_large_image',
            }}
            extend={{
                meta: [
                    { name: 'keywords', content: defaultKeywords.join(',') },
                    { name: 'author', content: site.name },
                    { name: 'robots', content: 'index, follow' },
                    { name: 'format-detection', content: 'telephone=no' },
                ],
                link: [{ rel: 'sitemap', type: 'application/xml', href: '/sitemap-index.xml' }],
            }}
        />

        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify({
                '@context': 'https://schema.org',
                '@type': 'Person',
                '@id': new URL('/#person', Astro.site).toString(),
                name: site.name,
                url: new URL('/', Astro.site).toString(),
                jobTitle: 'Software Developer',
                description: 'Software Developer and Designer from Passau, Germany',
                address: { '@type': 'PostalAddress', addressLocality: 'Passau', addressCountry: 'DE' },
                sameAs: socials.map((s) => s.href),
            })}
        />

        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify({
                '@context': 'https://schema.org',
                '@type': 'WebSite',
                '@id': new URL('/#website', Astro.site).toString(),
                name: `${site.name} | Portfolio`,
                url: new URL('/', Astro.site).toString(),
                inLanguage: 'en',
                publisher: { '@id': new URL('/#person', Astro.site).toString() },
            })}
        />
    </head>
    <body class="bg-bg text-fg min-h-svh antialiased">
        <a
            href="#top"
            class="bg-acid sr-only rounded-full px-4 py-2 font-mono text-xs text-black focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100]"
        >
            Skip to content
        </a>

        <SiteHeader />
        <slot />
        <SiteFooter />

        <div class="grain" aria-hidden="true"></div>
    </body>
</html>
